{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2020"],
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@layoutit/polycss-core": ["../core/src/index.ts"],
      "@layoutit/polycss-core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" }
  ]
}
