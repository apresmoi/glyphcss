{
  "name": "@glyphcss/vue",
  "version": "0.0.1",
  "description": "Native Vue 3 components for the glyphcss ASCII polygon mesh rendering engine.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": ["glyphcss", "ascii", "polygon", "mesh", "3d", "dom", "vue", "vue3", "rendering"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LayoutitStudio/polycss.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/LayoutitStudio/polycss/issues"
  },
  "homepage": "https://github.com/LayoutitStudio/polycss#readme",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@glyphcss/core": "workspace:^",
    "glyphcss": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.8.9",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.12"
  }
}
