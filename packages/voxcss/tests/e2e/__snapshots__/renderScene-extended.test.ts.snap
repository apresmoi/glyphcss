// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Snapshots — Extended > snapshot: dimetric projection with multiple layers 1`] = `"<div class="voxcss-camera" style="perspective: 8000px;"><div class="voxcss-scene voxcss-projection--dimetric" style="transform: scale(0.65) translateY(20px) translateY(0px) translateX(0px) rotateX(65deg) rotate(45deg); width: 100px; height: 100px; --voxcss-rows: 2; --voxcss-cols: 2;"><div class="voxcss-floor-z" style="pointer-events: none; background: none none;"><div class="voxcss-layer" style="transform: translateZ(0px);"><div style="grid-area: 0 / 0 / 1 / 1; --voxcss-side-offset-x: 25px; --voxcss-side-offset-y: 25px; --voxcss-fr-offset: 50px;" class="voxcss-cube"><div class="voxcss-cube-face voxcss-cube-face--fr" style="background-color: rgb(240, 0, 0);"></div><div class="voxcss-cube-face voxcss-cube-face--fl" style="background-color: rgb(230, 0, 0);"></div></div><div style="grid-area: 1 / 1 / 2 / 2; --voxcss-side-offset-x: 25px; --voxcss-side-offset-y: 25px; --voxcss-fr-offset: 50px;" class="voxcss-cube"><div class="voxcss-cube-face voxcss-cube-face--t" style="background-color: rgb(0, 0, 255);"></div><div class="voxcss-cube-face voxcss-cube-face--fr" style="background-color: rgb(0, 0, 240);"></div><div class="voxcss-cube-face voxcss-cube-face--fl" style="background-color: rgb(0, 0, 230);"></div></div></div><div class="voxcss-layer" style="transform: translateZ(25px);"><div style="grid-area: 0 / 0 / 1 / 1; --voxcss-side-offset-x: 25px; --voxcss-side-offset-y: 25px; --voxcss-fr-offset: 50px;" class="voxcss-cube"><div class="voxcss-cube-face voxcss-cube-face--t" style="background-color: rgb(0, 255, 0);"></div><div class="voxcss-cube-face voxcss-cube-face--fr" style="background-color: rgb(0, 240, 0);"></div><div class="voxcss-cube-face voxcss-cube-face--fl" style="background-color: rgb(0, 230, 0);"></div></div></div></div></div></div>"`;

exports[`Snapshots — Extended > snapshot: single ramp 1`] = `"<div class="voxcss-camera" style="perspective: 8000px;"><div class="voxcss-scene" style="transform: scale(0.65) translateY(20px) translateY(0px) translateX(0px) rotateX(65deg) rotate(45deg); width: 100px; height: 100px; --voxcss-rows: 2; --voxcss-cols: 2;"><div class="voxcss-floor-z" style="pointer-events: none; background: none none;"><div class="voxcss-layer" style="transform: translateZ(0px);"><div style="grid-area: 1 / 1 / 2 / 2;" class="voxcss-east voxcss-ramp"><div class="voxcss-ramp-slope" style="background-size: 70px 50px; background-color: rgb(40, 142, 108);"></div></div></div></div></div></div>"`;

exports[`Snapshots — Extended > snapshot: single spike 1`] = `"<div class="voxcss-camera" style="perspective: 8000px;"><div class="voxcss-scene" style="transform: scale(0.65) translateY(20px) translateY(0px) translateX(0px) rotateX(65deg) rotate(45deg); width: 100px; height: 100px; --voxcss-rows: 2; --voxcss-cols: 2;"><div class="voxcss-floor-z" style="pointer-events: none; background: none none;"><div class="voxcss-layer" style="transform: translateZ(0px);"><div style="grid-area: 1 / 1 / 2 / 2;" class="voxcss-east voxcss-spike"><div class="voxcss-spike-slope voxcss-spike-slope--primary"><svg viewBox="0 0 480 480" width="56" height="50" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" style="position: absolute; width: 100%; height: 100%; display: block; pointer-events: none;"><path d="M480 0 L480 480 L0 480 Z" fill="rgb(142, 108, 40)" stroke="rgba(0, 0, 0, 0.1)" stroke-width="1" vector-effect="non-scaling-stroke"></path></svg></div><div class="voxcss-spike-slope voxcss-spike-slope--secondary"><svg viewBox="0 0 480 480" width="50" height="56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" style="position: absolute; width: 100%; height: 100%; display: block; pointer-events: none;"><path d="M0 0 L0 480 L480 0 Z" fill="rgb(158, 124, 56)" stroke="rgba(0, 0, 0, 0.1)" stroke-width="1" vector-effect="non-scaling-stroke"></path></svg></div></div></div></div></div></div>"`;

