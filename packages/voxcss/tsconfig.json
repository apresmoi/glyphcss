{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@voxcss/*": ["./*"],
      "@layoutit/voxcss-core": ["../../core/src"],
      "@layoutit/voxcss-core/*": ["../../core/src/*"],
      "@layoutit/voxcss-html": ["../../html/src"],
      "@layoutit/voxcss-html/*": ["../../html/src/*"]
    },
    "outDir": "dist"
  },
  "include": ["src", "react", "vue"]
}
