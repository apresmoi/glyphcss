---
// PolyDemo — live interactive poly scene for docs pages.
// Usage in MDX:
//   <PolyDemo id="sphere-demo" generator="sphere"
//     generatorParams='{"subdivisions":3,"radius":10}'
//     controls='["zoom","rotX","rotY","perspective","subdivisions"]'
//     showStats />
//
//   <PolyDemo id="mesh-demo" model="/gallery/glb/ranger.glb"
//     controls='["zoom","rotX","rotY","perspective","interactive","animate"]'
//     defaults='{"rotX":65,"rotY":45}' />

interface Props {
  id: string;
  /** Mesh URL (GLB / OBJ) — loaded via <poly-mesh src>. */
  model?: string;
  /** Companion `.mtl` URL for OBJ models (Kd colors + map_Kd textures). */
  mtl?: string;
  /** Client-side generator name: "sphere" */
  generator?: string;
  /** JSON object of generator params (e.g. {"subdivisions":3,"radius":10}) */
  generatorParams?: string;
  /** JSON array of control names to render */
  controls?: string;
  /** JSON object of default values */
  defaults?: string;
  /** Show FPS + polygon count overlay */
  showStats?: boolean;
}

import '../styles/poly-demo.css';

const { id, model, mtl, generator, generatorParams, controls, defaults, showStats } = Astro.props;
---

<div class="poly-demo" id={id}
  data-model={model || undefined}
  data-mtl={mtl || undefined}
  data-generator={generator || undefined}
  data-generator-params={generatorParams || undefined}
  data-controls={controls}
  data-defaults={defaults}
  data-show-stats={showStats ? "1" : undefined}>
  <div class="poly-demo__viewer not-content">
    <div class="poly-demo__canvas">
      <div class="poly-demo__scene-host"></div>
      <div class="poly-demo__loading">Loading…</div>
      <div class="poly-demo__stats"></div>
    </div>
    <div class="poly-demo__controls"></div>
  </div>
  <div class="poly-demo__code not-content">
    <div class="poly-demo__tabs">
      <button class="poly-demo__tab active" data-fw="vanilla">Vanilla JS</button>
      <button class="poly-demo__tab" data-fw="react">React</button>
      <button class="poly-demo__tab" data-fw="vue">Vue</button>
    </div>
    <pre class="poly-demo__snippet" data-fw="vanilla"><code></code></pre>
    <pre class="poly-demo__snippet poly-demo__snippet--hidden" data-fw="react"><code></code></pre>
    <pre class="poly-demo__snippet poly-demo__snippet--hidden" data-fw="vue"><code></code></pre>
  </div>
</div>

<script>
  // Registry of per-demo cleanup functions, invoked on page navigation so the
  // previous page's renderers / FPS loops don't leak into the next page.
  var polyDemoCleanups: Array<() => void> = [];

  function cleanupPolyDemos() {
    for (var i = 0; i < polyDemoCleanups.length; i++) {
      try { polyDemoCleanups[i](); } catch (_) {}
    }
    polyDemoCleanups = [];
  }

  // ─── Sphere icosphere generator (ported from website/src/debug/pages/Sphere.tsx) ───

  type Vec3 = [number, number, number];
  interface Polygon { vertices: Vec3[]; color: string; }

  function buildSpherePolygons(radius: number, subdivisions: number, color = "#3b82f6"): Polygon[] {
    const r = Math.max(1, Math.floor(radius));
    const phi = (1 + Math.sqrt(5)) / 2;

    const initialVerts: Vec3[] = [
      [-1, phi, 0], [1, phi, 0], [-1, -phi, 0], [1, -phi, 0],
      [0, -1, phi], [0, 1, phi], [0, -1, -phi], [0, 1, -phi],
      [phi, 0, -1], [phi, 0, 1], [-phi, 0, -1], [-phi, 0, 1],
    ].map(([x, y, z]) => {
      const l = Math.hypot(x, y, z);
      return [x / l, y / l, z / l] as Vec3;
    });
    const initialFaces: [number, number, number][] = [
      [0, 11, 5], [0, 5, 1], [0, 1, 7], [0, 7, 10], [0, 10, 11],
      [1, 5, 9], [5, 11, 4], [11, 10, 2], [10, 7, 6], [7, 1, 8],
      [3, 9, 4], [3, 4, 2], [3, 2, 6], [3, 6, 8], [3, 8, 9],
      [4, 9, 5], [2, 4, 11], [6, 2, 10], [8, 6, 7], [9, 8, 1],
    ];

    let verts: Vec3[] = initialVerts;
    let faces: [number, number, number][] = initialFaces;
    for (let s = 0; s < subdivisions; s++) {
      const newVerts: Vec3[] = [...verts];
      const newFaces: [number, number, number][] = [];
      const midCache = new Map<string, number>();
      const midpoint = (i: number, j: number): number => {
        const key = i < j ? `${i}-${j}` : `${j}-${i}`;
        const cached = midCache.get(key);
        if (cached !== undefined) return cached;
        const a = verts[i], b = verts[j];
        let mx = (a[0] + b[0]) / 2, my = (a[1] + b[1]) / 2, mz = (a[2] + b[2]) / 2;
        const l = Math.hypot(mx, my, mz);
        mx /= l; my /= l; mz /= l;
        const idx = newVerts.length;
        newVerts.push([mx, my, mz]);
        midCache.set(key, idx);
        return idx;
      };
      for (const [a, b, c] of faces) {
        const ab = midpoint(a, b);
        const bc = midpoint(b, c);
        const ca = midpoint(c, a);
        newFaces.push([a, ab, ca]);
        newFaces.push([b, bc, ab]);
        newFaces.push([c, ca, bc]);
        newFaces.push([ab, bc, ca]);
      }
      verts = newVerts;
      faces = newFaces;
    }

    const grid: Vec3[] = verts.map(([x, y, z]) => [
      Math.round(r * x),
      Math.round(r * y),
      Math.round(r * z),
    ]);
    const out: Polygon[] = [];
    for (const [i, j, k] of faces) {
      out.push({ vertices: [grid[i], grid[j], grid[k]], color });
    }
    return out;
  }

  // ─── Platonic-solid generators ────────────────────────────────────────────────
  // Same shapes voxcss used to render as a "single block" demo, ported from
  // website/src/debug/platonicShapes.ts. All authored centered at origin so
  // they rotate around their centroid with autoCenter off.

  const PALETTE = [
    "#3b82f6", "#ef4444", "#22c55e", "#eab308",
    "#a855f7", "#06b6d4", "#f97316", "#ec4899",
  ];

  function buildCubePolygons(size: number): Polygon[] {
    const s = size;
    const c: Vec3[] = [
      [-s, -s, -s], [ s, -s, -s], [ s,  s, -s], [-s,  s, -s],
      [-s, -s,  s], [ s, -s,  s], [ s,  s,  s], [-s,  s,  s],
    ];
    const quads: number[][] = [
      [0, 3, 2, 1], [4, 5, 6, 7], [0, 1, 5, 4],
      [2, 3, 7, 6], [0, 4, 7, 3], [1, 2, 6, 5],
    ];
    return quads.map((q, i) => ({
      vertices: q.map((idx) => c[idx]) as unknown as Vec3[],
      color: PALETTE[i % PALETTE.length],
    }));
  }

  function buildTetrahedronPolygons(size: number): Polygon[] {
    const s = size;
    const v: Vec3[] = [
      [-s, -s, -s], [ s,  s, -s], [ s, -s,  s], [-s,  s,  s],
    ];
    const faces: [number, number, number][] = [[0,1,2],[0,3,1],[0,2,3],[1,3,2]];
    return faces.map((f, i) => ({
      vertices: [v[f[0]], v[f[1]], v[f[2]]],
      color: PALETTE[i % PALETTE.length],
    }));
  }

  function buildOctahedronPolygons(size: number): Polygon[] {
    const s = size;
    const v: Vec3[] = [
      [ s,  0,  0], [-s,  0,  0],
      [ 0,  s,  0], [ 0, -s,  0],
      [ 0,  0,  s], [ 0,  0, -s],
    ];
    const faces: [number, number, number][] = [
      [0,2,4],[2,1,4],[1,3,4],[3,0,4],
      [2,0,5],[1,2,5],[3,1,5],[0,3,5],
    ];
    return faces.map((f, i) => ({
      vertices: [v[f[0]], v[f[1]], v[f[2]]],
      color: PALETTE[i % PALETTE.length],
    }));
  }

  function buildIcosahedronPolygons(size: number): Polygon[] {
    const a = size, b = Math.round(size * 1.618);
    const v: Vec3[] = [
      [-a, b, 0], [a, b, 0], [-a, -b, 0], [a, -b, 0],
      [0, -a, b], [0, a, b], [0, -a, -b], [0, a, -b],
      [b, 0, -a], [b, 0, a], [-b, 0, -a], [-b, 0, a],
    ];
    const faces: [number, number, number][] = [
      [0,11,5],[0,5,1],[0,1,7],[0,7,10],[0,10,11],
      [1,5,9],[5,11,4],[11,10,2],[10,7,6],[7,1,8],
      [3,9,4],[3,4,2],[3,2,6],[3,6,8],[3,8,9],
      [4,9,5],[2,4,11],[6,2,10],[8,6,7],[9,8,1],
    ];
    return faces.map((f, i) => ({
      vertices: [v[f[0]], v[f[1]], v[f[2]]],
      color: PALETTE[i % PALETTE.length],
    }));
  }

  function buildDodecahedronPolygons(size: number): Polygon[] {
    // Fibonacci triple (s, a, b) ≈ φ ratios. Same vertex layout as
    // /debug/platonicShapes; emitted as 12 native pentagons (NOT
    // fan-triangulated) so each face is a single atlas-backed polygon. Shows off
    // polycss's N-vertex polygon support — voxcss couldn't do this.
    const s = size;
    const a = Math.round(size * 8 / 13);
    const b = Math.round(size * 21 / 13);
    const v: Vec3[] = [
      [-s, -s, -s], [-s, -s,  s], [-s,  s, -s], [-s,  s,  s],
      [ s, -s, -s], [ s, -s,  s], [ s,  s, -s], [ s,  s,  s],
      [ 0, -b, -a], [ 0, -b,  a], [ 0,  b, -a], [ 0,  b,  a],
      [-a,  0, -b], [-a,  0,  b], [ a,  0, -b], [ a,  0,  b],
      [-b, -a,  0], [-b,  a,  0], [ b, -a,  0], [ b,  a,  0],
    ];
    const pentagons: number[][] = [
      [7, 11, 3, 13, 15], [7, 15, 5, 18, 19], [7, 19, 6, 10, 11],
      [6, 19, 18, 4, 14], [6, 14, 12, 2, 10], [5, 15, 13, 1, 9],
      [5, 9, 8, 4, 18], [4, 8, 0, 12, 14], [3, 17, 16, 1, 13],
      [3, 11, 10, 2, 17], [2, 12, 0, 16, 17], [1, 16, 0, 8, 9],
    ];
    return pentagons.map((p, i) => ({
      vertices: p.map((idx) => v[idx]) as unknown as Vec3[],
      color: PALETTE[i % PALETTE.length],
    }));
  }

  function buildPlatonic(shape: string, size: number): Polygon[] {
    switch (shape) {
      case "cube": return buildCubePolygons(size);
      case "tetrahedron": return buildTetrahedronPolygons(size);
      case "octahedron": return buildOctahedronPolygons(size);
      case "icosahedron": return buildIcosahedronPolygons(size);
      case "dodecahedron": return buildDodecahedronPolygons(size);
      default: return buildCubePolygons(size);
    }
  }

  const PLATONIC_SHAPES = ["tetrahedron", "cube", "octahedron", "dodecahedron", "icosahedron"];

  // ─── Main init ────────────────────────────────────────────────────────────────

  async function initPolyDemos() {
    // Load highlight.js for syntax highlighting
    var hljs: any = null;
    try {
      var hljsMod = await import("highlight.js/lib/core");
      hljs = hljsMod.default;
      var xmlMod = await import("highlight.js/lib/languages/xml");
      var jsMod = await import("highlight.js/lib/languages/javascript");
      var tsMod = await import("highlight.js/lib/languages/typescript");
      hljs.registerLanguage("html", xmlMod.default);
      hljs.registerLanguage("xml", xmlMod.default);
      hljs.registerLanguage("vue", xmlMod.default);
      hljs.registerLanguage("javascript", jsMod.default);
      hljs.registerLanguage("tsx", tsMod.default);
    } catch (e) {
      hljs = null;
    }

    for (const el of document.querySelectorAll(".poly-demo")) {
      const demoEl = el as HTMLElement;
      if (demoEl.getAttribute("data-initialized")) continue;
      demoEl.setAttribute("data-initialized", "1");

      const modelSrc = demoEl.getAttribute("data-model");
      const modelMtl = demoEl.getAttribute("data-mtl");
      // The shape control (when listed) lets the user switch between
      // platonic solids at runtime. The HTML `data-generator` attribute
      // sets the initial shape; PLATONIC_SHAPES drives the selector.
      let generatorName = demoEl.getAttribute("data-generator");
      const controlsData = demoEl.getAttribute("data-controls");
      const defaultsData = demoEl.getAttribute("data-defaults");
      const generatorParamsData = demoEl.getAttribute("data-generator-params");
      const wantStats = demoEl.getAttribute("data-show-stats") === "1";

      let controlList: string[] = [];
      try { controlList = JSON.parse(controlsData || "[]"); } catch {}

      let defaults: Record<string, any> = {};
      try { defaults = JSON.parse(defaultsData || "{}"); } catch {}

      let generatorParams: Record<string, any> = {};
      try { generatorParams = JSON.parse(generatorParamsData || "{}"); } catch {}

      const sceneHost = demoEl.querySelector(".poly-demo__scene-host") as HTMLElement;
      const loadingEl = demoEl.querySelector(".poly-demo__loading") as HTMLElement;
      const controlsEl = demoEl.querySelector(".poly-demo__controls") as HTMLElement;
      const statsEl = demoEl.querySelector(".poly-demo__stats") as HTMLElement;
      const codeEls: Record<string, HTMLElement | null> = {
        react: demoEl.querySelector('.poly-demo__snippet[data-fw="react"] code'),
        vue: demoEl.querySelector('.poly-demo__snippet[data-fw="vue"] code'),
        vanilla: demoEl.querySelector('.poly-demo__snippet[data-fw="vanilla"] code'),
      };

      if (!sceneHost) continue;

      // Tab switching
      demoEl.querySelector(".poly-demo__tabs")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".poly-demo__tab") as HTMLElement | null;
        if (!btn) return;
        const fw = btn.dataset.fw;
        demoEl.querySelectorAll(".poly-demo__tab").forEach((t) =>
          t.classList.toggle("active", (t as HTMLElement).dataset.fw === fw)
        );
        demoEl.querySelectorAll(".poly-demo__snippet").forEach((p) =>
          p.classList.toggle("poly-demo__snippet--hidden", (p as HTMLElement).dataset.fw !== fw)
        );
        if (fw) {
          const labelMap: Record<string, string> = { react: "React", vue: "Vue", vanilla: "Vanilla JS" };
          try { localStorage.setItem("starlight-synced-tabs__fw", labelMap[fw] || fw); } catch {}
        }
      });

      // Restore from Starlight's synced tab preference
      try {
        const saved = localStorage.getItem("starlight-synced-tabs__fw");
        const fwMap: Record<string, string> = { "React": "react", "Vue": "vue", "Vanilla JS": "vanilla" };
        const fw = saved ? fwMap[saved] : null;
        if (fw) {
          demoEl.querySelectorAll(".poly-demo__tab").forEach((t) =>
            t.classList.toggle("active", (t as HTMLElement).dataset.fw === fw)
          );
          demoEl.querySelectorAll(".poly-demo__snippet").forEach((p) =>
            p.classList.toggle("poly-demo__snippet--hidden", (p as HTMLElement).dataset.fw !== fw)
          );
        }
      } catch {}

      // State — defaults merged with user overrides.
      // `light` is a partial DirectionalLight ({ direction?, color?, ambient?,
      // ambientColor? }) — `undefined` falls through to the renderer's
      // default (ambient 0.35, key direction [0.4,-0.7,0.59], white). Demos
      // bump ambient to brighten dim assets like trees / dark GLBs.
      const rendererDefaultPerspective = 8000;
      const state: Record<string, any> = {
        zoom: defaults.zoom ?? 1,
        rotX: defaults.rotX ?? 65,
        rotY: defaults.rotY ?? 45,
        perspective: defaults.perspective ?? false,
        interactive: defaults.interactive ?? false,
        animate: defaults.animate ?? false,
        merge: defaults.merge ?? "off",
        light: defaults.light,
        // Generator-specific state (sphere)
        subdivisions: generatorParams.subdivisions ?? defaults.subdivisions ?? 3,
        radius: generatorParams.radius ?? defaults.radius ?? 10,
        color: generatorParams.color ?? defaults.color ?? "#3b82f6",
        // Tracked stats
        polyCount: 0,
      };

      // ─── Build the poly-scene custom element ───────────────────────────────
      // We import the element classes from polycss and register them ourselves
      // (avoids the polycss/elements subpath which Astro/Vite's <script> pass
      // can fail to resolve cleanly). Markup is built programmatically so
      // Astro SSR never sees the custom tags.

      async function ensureCustomElementsRegistered() {
        const polycss = await import("polycss");
        const tag = (name: string, cls: any) => {
          if (!customElements.get(name)) customElements.define(name, cls);
        };
        tag("poly-scene", polycss.PolySceneElement);
        tag("poly-mesh", polycss.PolyMeshElement);
        tag("poly-polygon", polycss.PolyPolygonElement);
      }

      let sceneEl: HTMLElement | null = null;
      let meshEl: HTMLElement | null = null;
      let animFrameId: number | null = null;
      let sceneHandle: any = null; // createPolyScene handle for generator mode

      function perspectiveOverride() {
        return state.perspective === rendererDefaultPerspective ? undefined : state.perspective;
      }

      function buildSceneAttrs() {
        const attrs: Record<string, string> = {
          "rot-x": String(state.rotX),
          "rot-y": String(state.rotY),
          "zoom": String(state.zoom),
          "auto-center": "",
        };
        const perspective = perspectiveOverride();
        if (perspective !== undefined) attrs["perspective"] = String(perspective);
        if (state.merge && state.merge !== "off") attrs["merge"] = state.merge;
        if (state.interactive) attrs["interactive"] = "";
        if (state.light) {
          if (state.light.direction) attrs["light-direction"] = state.light.direction.join(",");
          if (state.light.color) attrs["light-color"] = state.light.color;
          if (state.light.ambient !== undefined) attrs["light-ambient"] = String(state.light.ambient);
          if (state.light.ambientColor) attrs["light-ambient-color"] = state.light.ambientColor;
        }
        return attrs;
      }

      function applySceneAttrs() {
        if (!sceneEl) return;
        const attrs = buildSceneAttrs();
        for (const [k, v] of Object.entries(attrs)) {
          sceneEl.setAttribute(k, v);
        }
        // Remove attrs that should be absent
        if (!state.merge || state.merge === "off") sceneEl.removeAttribute("merge");
        if (perspectiveOverride() === undefined) sceneEl.removeAttribute("perspective");
        if (!state.interactive) sceneEl.removeAttribute("interactive");
      }

      // ── Animation loop ──────────────────────────────────────────────────────
      let animRotY = state.rotY;
      let lastAnimTime = 0;
      const ANIM_SPEED = 0.3; // deg/frame at 60fps ≈ 18 deg/s

      function animTick(now: number) {
        if (animFrameId === null) return;
        const dt = Math.min(50, now - (lastAnimTime || now));
        lastAnimTime = now;
        animRotY = (animRotY + ANIM_SPEED * (dt / 16.67)) % 360;
        // Generator mode: sceneEl is a plain <div> wrapping the imperative
        // scene handle — drive rotation via setOptions, not attributes.
        // Model mode: sceneEl is <poly-scene> and attribute changes trigger
        // its own re-render path.
        if (sceneHandle) {
          sceneHandle.setOptions({ rotY: animRotY });
        } else if (sceneEl) {
          sceneEl.setAttribute("rot-y", String(animRotY.toFixed(2)));
        }
        animFrameId = requestAnimationFrame(animTick);
      }

      function startAnim() {
        if (animFrameId !== null) return;
        lastAnimTime = 0;
        animFrameId = requestAnimationFrame(animTick);
      }
      function stopAnim() {
        if (animFrameId !== null) {
          cancelAnimationFrame(animFrameId);
          animFrameId = null;
        }
      }

      // ── FPS counting ─────────────────────────────────────────────────────────
      let fpsFrameId: number | null = null;
      let fpsFrames = 0;
      let fpsSampleStart = 0;
      let currentFps = "-";

      function fpsTick(now: number) {
        if (fpsFrameId === null) return;
        if (!fpsSampleStart) fpsSampleStart = now;
        fpsFrames += 1;
        const elapsed = now - fpsSampleStart;
        if (elapsed >= 1000) {
          currentFps = String(Math.round((fpsFrames * 1000) / elapsed));
          fpsFrames = 0;
          fpsSampleStart = now;
          updateStats();
        }
        fpsFrameId = requestAnimationFrame(fpsTick);
      }

      if (wantStats) {
        statsEl?.classList.add("active");
        fpsFrameId = requestAnimationFrame(fpsTick);
      }

      function updateStats() {
        if (!wantStats || !statsEl) return;
        statsEl.innerHTML =
          "FPS: <span class='stat-value'>" + currentFps + "</span> · " +
          "Polygons: <span class='stat-value'>" + state.polyCount.toLocaleString() + "</span>";
      }

      // ── Scene init for model mode ──────────────────────────────────────────
      async function initModelScene() {
        // Register custom elements
        await ensureCustomElementsRegistered();

        sceneEl = document.createElement("poly-scene");
        const attrs = buildSceneAttrs();
        for (const [k, v] of Object.entries(attrs)) {
          sceneEl.setAttribute(k, v);
        }
        sceneEl.style.cssText = "width:100%;height:100%;position:absolute;inset:0;";

        meshEl = document.createElement("poly-mesh");
        meshEl.setAttribute("src", modelSrc!);
        if (modelMtl) meshEl.setAttribute("mtl", modelMtl);
        meshEl.setAttribute("auto-center", "");

        // Track polygon count when mesh loads
        meshEl.addEventListener("polycss:loaded", (e: any) => {
          state.polyCount = (e.detail?.polygons?.length) ?? 0;
          loadingEl.style.display = "none";
          updateStats();
        });
        meshEl.addEventListener("polycss:error", () => {
          loadingEl.textContent = "Failed to load mesh.";
        });

        sceneEl.appendChild(meshEl);
        sceneHost.appendChild(sceneEl);
      }

      // ── Scene init for generator mode ─────────────────────────────────────
      async function initGeneratorScene() {
        const { createPolyScene } = await import("polycss");

        sceneEl = document.createElement("div");
        sceneEl.style.cssText = "width:100%;height:100%;position:absolute;inset:0;";
        sceneHost.appendChild(sceneEl);

        const sceneOptions: Record<string, any> = {
          rotX: state.rotX,
          rotY: state.rotY,
          zoom: state.zoom,
          autoCenter: true,
          interactive: state.interactive,
        };
        const perspective = perspectiveOverride();
        if (perspective !== undefined) sceneOptions.perspective = perspective;
        if (state.merge && state.merge !== "off") sceneOptions.merge = state.merge;
        if (state.light) sceneOptions.directionalLight = state.light;

        sceneHandle = createPolyScene(sceneEl as HTMLElement, sceneOptions);
        await rebuildGeneratorMesh();
        loadingEl.style.display = "none";
      }

      let currentMeshHandle: any = null;

      async function rebuildGeneratorMesh() {
        if (!sceneHandle) return;
        if (currentMeshHandle) {
          currentMeshHandle.remove();
          currentMeshHandle = null;
        }

        if (generatorName === "sphere") {
          const polygons = buildSpherePolygons(state.radius, state.subdivisions, state.color);
          state.polyCount = polygons.length;
          updateStats();
          const parseResult = { polygons, dispose: () => {} };
          currentMeshHandle = sceneHandle.add(parseResult);
        } else if (generatorName && PLATONIC_SHAPES.includes(generatorName)) {
          const polygons = buildPlatonic(generatorName, state.radius);
          state.polyCount = polygons.length;
          updateStats();
          const parseResult = { polygons, dispose: () => {} };
          currentMeshHandle = sceneHandle.add(parseResult);
        }
        updateCode();
      }

      // ── Update camera from state (model mode uses attributes) ──────────────
      function updateCamera() {
        if (sceneHandle) {
          // Generator mode — use imperative API
          sceneHandle.setOptions({
            rotX: state.rotX,
            rotY: state.rotY,
            perspective: perspectiveOverride(),
            zoom: state.zoom,
            autoCenter: true,
            interactive: state.interactive,
          });
        } else {
          // applySceneAttrs handles `interactive` and merge
          // alongside the rotation/zoom attrs.
          applySceneAttrs();
        }
        if (state.animate) {
          animRotY = state.rotY;
          startAnim();
        } else {
          stopAnim();
        }
        updateCode();
      }

      function updateScene() {
        if (sceneHandle) {
          rebuildGeneratorMesh();
        } else {
          applySceneAttrs();
        }
        updateCode();
      }

      // ── Code snippet generation ────────────────────────────────────────────
      function updateCode() {
        const cp: Record<string, string> = {};
        if (state.zoom !== 1) cp.zoom = state.zoom.toFixed(2);
        if (state.rotX !== 65) cp.rotX = String(state.rotX);
        if (state.rotY !== 45) cp.rotY = String(state.rotY);
        if (state.perspective !== rendererDefaultPerspective) cp.perspective = String(state.perspective);
        if (state.animate) cp.animate = "true";

        const sp: Record<string, string> = {};
        if (state.merge && state.merge !== "off") sp.merge = `"${state.merge}"`;

        // ── React snippet ──────────────────────────────────────────────────
        if (codeEls.react) {
          const r: string[] = ['import { PolyScene, PolyMesh } from "@polycss/react";', ""];
          r.push("export function App() {");
          r.push("  return (");

          const camAttrs = Object.entries(cp).map(([k, v]) =>
            v === "true" ? k : `${k}={${v}}`
          );
          const sceneAttrs = Object.entries(sp).map(([k, v]) =>
            v === "true" ? k : `${k}={${v}}`
          );
          const allAttrs = [...camAttrs, ...sceneAttrs];

          if (modelSrc) {
            if (allAttrs.length <= 3) {
              r.push("    <PolyScene " + allAttrs.join(" ") + ">");
            } else {
              r.push("    <PolyScene");
              allAttrs.forEach((a) => r.push("      " + a));
              r.push("    >");
            }
            r.push('      <PolyMesh src="' + modelSrc + '"' + (modelMtl ? ' mtl="' + modelMtl + '"' : '') + ' />');
            r.push("    <" + "/PolyScene>");
          } else if (generatorName) {
            const fnCall =
              generatorName === "sphere"
                ? `buildSpherePolygons(${state.radius}, ${state.subdivisions})`
                : `build${generatorName.charAt(0).toUpperCase()}${generatorName.slice(1)}Polygons(${state.radius})`;
            r[0] = 'import { PolyScene, Poly } from "@polycss/react";';
            r.splice(1, 0, '');
            r.splice(2, 0, `const polygons = ${fnCall};`);
            r.splice(3, 0, '');
            if (allAttrs.length <= 3) {
              r.push("    <PolyScene " + allAttrs.join(" ") + ">");
            } else {
              r.push("    <PolyScene");
              allAttrs.forEach((a) => r.push("      " + a));
              r.push("    >");
            }
            r.push("      {polygons.map((p, i) => <Poly key={i} {...p} />)}");
            r.push("    <" + "/PolyScene>");
          }

          r.push("  );");
          r.push("}");
          codeEls.react.textContent = r.join("\n");
        }

        // ── Vue snippet ───────────────────────────────────────────────────
        if (codeEls.vue) {
          const vueCamAttrs = Object.entries(cp).map(([k, v]) => {
            const attr = k.replace(/([A-Z])/g, "-$1").toLowerCase();
            return v === "true" ? attr : `:${attr}="${v}"`;
          });
          const vueSceneAttrs = Object.entries(sp).map(([k, v]) => {
            const attr = k.replace(/([A-Z])/g, "-$1").toLowerCase();
            return v === "true" ? attr : `:${attr}="${v}"`;
          });
          const allVue = [...vueCamAttrs, ...vueSceneAttrs];
          const v: string[] = ["<template>"];

          if (modelSrc) {
            if (allVue.length <= 3) {
              v.push("  <PolyScene " + allVue.join(" ") + ">");
            } else {
              v.push("  <PolyScene");
              allVue.forEach((a) => v.push("    " + a));
              v.push("  >");
            }
            v.push('    <PolyMesh src="' + modelSrc + '"' + (modelMtl ? ' mtl="' + modelMtl + '"' : '') + ' />');
            v.push("  <" + "/PolyScene>");
          } else if (generatorName) {
            if (allVue.length <= 3) {
              v.push("  <PolyScene " + allVue.join(" ") + ">");
            } else {
              v.push("  <PolyScene");
              allVue.forEach((a) => v.push("    " + a));
              v.push("  >");
            }
            v.push("    <Poly v-for=\"(p, i) in polygons\" :key=\"i\" v-bind=\"p\" />");
            v.push("  <" + "/PolyScene>");
          }

          v.push("<" + "/template>");
          v.push("");
          v.push("<" + "script setup lang=\"ts\">");
          if (modelSrc) {
            v.push('import { PolyScene, PolyMesh } from "@polycss/vue";');
          } else if (generatorName) {
            const fnCall =
              generatorName === "sphere"
                ? `buildSpherePolygons(${state.radius}, ${state.subdivisions})`
                : `build${generatorName.charAt(0).toUpperCase()}${generatorName.slice(1)}Polygons(${state.radius})`;
            v.push('import { PolyScene, Poly } from "@polycss/vue";');
            v.push("import { computed } from \"vue\";");
            v.push(`const polygons = computed(() => ${fnCall});`);
          }
          v.push("<" + "/script>");
          codeEls.vue.textContent = v.join("\n");
        }

        // ── Vanilla snippet ───────────────────────────────────────────────
        if (codeEls.vanilla) {
          const j: string[] = [];
          const htmlAttrs: string[] = [];
          if (state.zoom !== 1) htmlAttrs.push(`  zoom="${state.zoom.toFixed(2)}"`);
          if (state.rotX !== 65) htmlAttrs.push(`  rot-x="${state.rotX}"`);
          if (state.rotY !== 45) htmlAttrs.push(`  rot-y="${state.rotY}"`);
          if (state.perspective !== rendererDefaultPerspective) htmlAttrs.push(`  perspective="${state.perspective}"`);
          if (state.merge && state.merge !== "off") htmlAttrs.push(`  merge="${state.merge}"`);
          htmlAttrs.push('  auto-center');

          j.push('<script type="module" src="https://esm.sh/polycss/elements"><' + "/script>");
          j.push("");
          if (modelSrc) {
            if (htmlAttrs.length <= 2) {
              j.push(`<poly-scene ${htmlAttrs.join(" ").trim()}>`);
            } else {
              j.push("<poly-scene");
              htmlAttrs.forEach((a) => j.push(a));
              j.push(">");
            }
            j.push(`  <poly-mesh src="${modelSrc}"${modelMtl ? ` mtl="${modelMtl}"` : ""}></poly-mesh>`);
            j.push("<" + "/poly-scene>");
          } else if (generatorName) {
            const fnCall =
              generatorName === "sphere"
                ? `buildSpherePolygons(${state.radius}, ${state.subdivisions})`
                : `build${generatorName.charAt(0).toUpperCase()}${generatorName.slice(1)}Polygons(${state.radius})`;
            j.push(`<!-- Polygons generated client-side via the imperative API: -->`);
            j.push('<script type="module">');
            j.push('import { createPolyScene } from "https://esm.sh/polycss";');
            j.push("");
            j.push("const host = document.getElementById(\"scene\");");
            j.push("const scene = createPolyScene(host, {");
            if (state.rotX !== 65) j.push(`  rotX: ${state.rotX},`);
            if (state.rotY !== 45) j.push(`  rotY: ${state.rotY},`);
            if (state.perspective !== rendererDefaultPerspective) j.push(`  perspective: ${state.perspective},`);
            j.push("  autoCenter: true,");
            j.push("});");
            j.push(`const polygons = ${fnCall};`);
            j.push("scene.add({ polygons, dispose: () => {} });");
            j.push("<" + "/script>");
          }

          codeEls.vanilla.textContent = j.join("\n");
        }

        // Apply syntax highlighting
        if (hljs) {
          const langMap: Record<string, string> = { react: "tsx", vue: "xml", vanilla: "html" };
          for (const fw of ["react", "vue", "vanilla"]) {
            const codeEl = codeEls[fw];
            if (codeEl && codeEl.textContent) {
              const lang = langMap[fw] || "javascript";
              try {
                codeEl.innerHTML = hljs.highlight(codeEl.textContent, { language: lang }).value;
              } catch (e) {}
            }
          }
        }
      }

      // ── Build controls ────────────────────────────────────────────────────
      function makeRange(
        label: string,
        min: number, max: number, step: number, initial: number,
        onChange: (v: number) => void,
        unit = ""
      ): HTMLElement {
        const wrapper = document.createElement("label");
        const heading = document.createElement("span");
        heading.className = "range-heading";
        const nameSpan = document.createElement("span");
        nameSpan.textContent = label;
        const valueSpan = document.createElement("span");
        valueSpan.className = "range-value";
        const fmt = (v: number) => step < 1 ? v.toFixed(2) : String(Math.round(v));
        valueSpan.textContent = fmt(initial) + unit;
        heading.append(nameSpan, valueSpan);

        const input = document.createElement("input");
        input.type = "range";
        input.min = String(min);
        input.max = String(max);
        input.step = String(step);
        input.value = String(initial);
        input.addEventListener("input", () => {
          const v = parseFloat(input.value);
          valueSpan.textContent = fmt(v) + unit;
          onChange(v);
        });

        wrapper.append(heading, input);
        return wrapper;
      }

      function makeSwitch(label: string, initial: boolean, onChange: (v: boolean) => void): HTMLElement {
        const wrapper = document.createElement("label");
        wrapper.className = "switch";
        const input = document.createElement("input");
        input.type = "checkbox";
        input.checked = initial;
        input.addEventListener("change", () => onChange(input.checked));
        const span = document.createElement("span");
        span.textContent = label;
        wrapper.append(input, span);
        return wrapper;
      }

      function makeSelect(label: string, options: string[], initial: string, onChange: (v: string) => void): HTMLElement {
        const wrapper = document.createElement("label");
        wrapper.className = "select";
        const heading = document.createElement("span");
        heading.textContent = label;
        const sel = document.createElement("select");
        for (const opt of options) {
          const o = document.createElement("option");
          o.value = opt;
          o.textContent = opt;
          if (opt === initial) o.selected = true;
          sel.appendChild(o);
        }
        sel.addEventListener("change", () => onChange(sel.value));
        wrapper.append(heading, sel);
        return wrapper;
      }

      const controlDefs: Record<string, () => HTMLElement> = {
        zoom: () => makeRange("zoom", 0.1, 3, 0.01, state.zoom, (v) => { state.zoom = v; updateCamera(); }),
        rotX: () => makeRange("rotX", 0, 90, 1, state.rotX, (v) => { state.rotX = v; updateCamera(); }, "°"),
        rotY: () => makeRange("rotY", 0, 360, 1, state.rotY, (v) => { state.rotY = v; animRotY = v; updateCamera(); }, "°"),
        perspective: () => makeRange("perspective", 200, 12000, 100, state.perspective === false ? rendererDefaultPerspective : state.perspective, (v) => { state.perspective = v; updateCamera(); }, "px"),
        interactive: () => makeSwitch("interactive", state.interactive, (v) => { state.interactive = v; updateCamera(); }),
        animate: () => makeSwitch("animate", state.animate, (v) => { state.animate = v; updateCamera(); }),
        merge: () => makeSwitch("merge coplanar", state.merge === "auto", (v) => { state.merge = v ? "auto" : "off"; updateScene(); }),
        // Sphere-specific controls
        subdivisions: () => makeRange("subdivisions", 0, 5, 1, state.subdivisions, (v) => { state.subdivisions = Math.round(v); rebuildGeneratorMesh(); updateCode(); }),
        radius: () => makeRange("radius", 2, 20, 1, state.radius, (v) => { state.radius = Math.round(v); rebuildGeneratorMesh(); updateCode(); }),
        // Platonic-shape selector — switches the generator at runtime so a
        // single demo can showcase all 5 regular polyhedra.
        shape: () => makeSelect("shape", PLATONIC_SHAPES, generatorName ?? "cube", (v) => {
          generatorName = v;
          rebuildGeneratorMesh();
          updateCode();
        }),
      };

      for (const key of controlList) {
        const maker = controlDefs[key];
        if (maker) controlsEl.appendChild(maker());
      }

      if (controlList.length === 0) {
        controlsEl.style.display = "none";
        const viewer = demoEl.querySelector(".poly-demo__viewer") as HTMLElement;
        if (viewer) viewer.style.gridTemplateColumns = "1fr";
      }

      // ── Initialize the scene ──────────────────────────────────────────────
      try {
        if (modelSrc) {
          await initModelScene();
        } else if (generatorName) {
          await initGeneratorScene();
          loadingEl.style.display = "none";
        }
        // Canonical "apply state → scene" pass. Picks up any defaults that
        // wouldn't otherwise be applied at first mount: animate (starts the
        // RAF loop), interactive (model mode attaches the attribute), merge
        // and merge (re-applied through the same path the sliders use).
        // Without this, `defaults: { animate: true }` only takes effect after
        // the user toggles the slider.
        updateCamera();
      } catch (err) {
        loadingEl.textContent = "Error initializing demo.";
        console.error("PolyDemo init error:", err);
      }

      updateCode();
      updateStats();

      // ── Cleanup for Astro view transitions ────────────────────────────────
      polyDemoCleanups.push(function() {
        stopAnim();
        if (fpsFrameId !== null) {
          try { cancelAnimationFrame(fpsFrameId); } catch (_) {}
          fpsFrameId = null;
        }
        if (sceneHandle) {
          try { sceneHandle.destroy(); } catch (_) {}
          sceneHandle = null;
        }
        try { demoEl.removeAttribute("data-initialized"); } catch (_) {}
      });
    }
  }

  // Tear down renderers before Astro swaps pages
  document.addEventListener("astro:before-swap", cleanupPolyDemos);

  // Run on initial load and after Astro View Transitions
  document.addEventListener("astro:page-load", function() { initPolyDemos(); });
  if (document.readyState !== "loading") {
    initPolyDemos();
  } else {
    document.addEventListener("DOMContentLoaded", function() { initPolyDemos(); });
  }
</script>
