  <span class="site-title__cursor" aria-hidden="true">_</span>
</a>
<style>
  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: rgba(255, 232, 184, 0.94);
    font-family: ui-monospace, "JetBrains Mono", "SF Mono", "Menlo", monospace;
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
    letter-spacing: 0;
  }
  .site-title__bracket {
    color: rgba(56, 189, 248, 0.85);
  }
  .site-title__name {
