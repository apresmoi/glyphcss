---
import hljs from "highlight.js/lib/core";
import xml from "highlight.js/lib/languages/xml";
import javascript from "highlight.js/lib/languages/javascript";
import typescript from "highlight.js/lib/languages/typescript";

hljs.registerLanguage("html", xml);
hljs.registerLanguage("xml", xml);
hljs.registerLanguage("javascript", javascript);
hljs.registerLanguage("tsx", typescript);
hljs.registerLanguage("vue", xml);

function highlight(code: string, lang: string): string {
  return hljs.highlight(code, { language: lang }).value;
}

const title = "polycss — CSS polygon-mesh renderer for the DOM";
const description = "Render textured 3D meshes in the DOM. No WebGL — each polygon is a real DOM element you can style, click, and inspect in DevTools.";
const siteUrl = "https://polycss.com";
// Reusing the legacy voxcss social card until a polycss-specific image lands.
const ogImage = `${siteUrl}/voxcss-intro.png`;

const frameworkTabs = [
  {
    id: "vanilla",
    label: "vanilla js",
    language: "html",
    code: `<script type="module" src="https://esm.sh/polycss/elements"></script>

<poly-scene perspective="1000" rot-x="65" rot-y="45">
  <poly-mesh src="/cottage.glb"></poly-mesh>
</poly-scene>`,
  },
  {
    id: "react",
    label: "React",
    language: "tsx",
    code: `import { PolyScene, PolyMesh } from "@polycss/react";

export function App() {
  return (
    <PolyScene rotX={65} rotY={45} perspective={1000}>
      <PolyMesh src="/cottage.glb" />
    </PolyScene>
  );
}`,
  },
  {
    id: "vue",
    label: "Vue",
    language: "vue",
    code: `<template>
  <PolyScene :rot-x="65" :rot-y="45" :perspective="1000">
    <PolyMesh src="/cottage.glb" />
  </PolyScene>
</template>
<script setup lang="ts">
import { PolyScene, PolyMesh } from "@polycss/vue";
</script>`,
  },
].map(tab => ({
  ...tab,
  highlighted: highlight(tab.code, tab.language),
}));

const installCmds = [
  "npm install polycss",
  "npm install @polycss/react",
  "npm install @polycss/vue",
].map(cmd => ({ code: cmd, highlighted: highlight(cmd, "javascript") }));

const ldJson = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "polycss",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description,
  url: siteUrl,
  image: ogImage,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  sameAs: ["https://github.com/LayoutitStudio/polycss"],
  publisher: {
    "@type": "Organization",
    name: "polycss",
    url: siteUrl,
  },
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
  <style>
    html { background: #0b0d10; color: #e2e8f0; }
    body { margin: 0; }
  </style>
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
</head>
<body>
  <div class="docs-shell">
    <aside class="docs-nav">
      <nav>
        <div class="docs-nav__brand"></div>
        <div class="nav-group">
          <ul>
            <li><a href="/" class="active">Home</a></li>
            <li><a href="/quickstart">Usage</a></li>
            <li><a href="/api/headless"><span class="nav-label"><span class="nav-label__short">API</span><span class="nav-label__long"> Reference</span></span></a></li>
            <li><a href="/gallery">Gallery</a></li>
          </ul>
        </div>
        <div class="docs-nav__spacer"></div>
      </nav>
    </aside>

    <main class="docs-content">
      <div class="home">
        <section class="hero" id="hero">
          <div class="hero-copy">
            <h1><img width="300" height="72" style="width: 300px; height: auto" src="/voxisologo.png" alt="polycss" /></h1>
            <p>
              Render textured 3D meshes in the DOM with CSS.
              No WebGL or &lt;canvas&gt; needed: each polygon is a real DOM element.
            </p>
            <p>
              Supports OBJ, glTF, and GLB file formats, including UV textures
              and material colors. Works with vanilla JS, React, and Vue.
            </p>
            <hr />
            <div class="cta">
              <a
                class="github-social"
                href="https://github.com/LayoutitStudio/polycss"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="github-social__main">
                  <svg class="github-social__icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                  </svg>
                  <span>View on GitHub</span>
                </span>
                <span class="github-social__count" id="star-count-hero">&#9733; &hellip;</span>
              </a>
            </div>
            <div class="install-logos" aria-label="Supported runtimes">
              <img class="install-logo" src="/jslogo.png" alt="Vanilla JS" />
              <img class="install-logo" src="/vuelogo.svg" alt="Vue" />
              <img class="install-logo" src="/reactlogo.svg" alt="React" />
            </div>
          </div>
          <div class="hero-canvas" id="hero-root">
            <!-- Rock environment OBJ mounted with createPolyScene + loadMesh,
                 autoCenter, and drag-to-rotate. -->
          </div>
        </section>

        <section class="install" id="install">
          <header class="install-header">
            <div>
              <h2>Installation</h2>
            </div>
          </header>
          <div class="install-list">
            <div class="install-row">
              <p class="install-label">Package managers</p>
              <div class="install-content">
                {installCmds.map(cmd => (
                  <pre class="dark-scrollbar"><code class="language-bash hljs" set:html={cmd.highlighted} /></pre>
                ))}
              </div>
            </div>
            <div class="install-row">
              <p class="install-label">CDN</p>
              <div class="install-content">
                <pre class="dark-scrollbar"><code class="language-html hljs" set:html={highlight('<script type="module" src="https://esm.sh/polycss/elements"></script>', "html")} /></pre>
              </div>
            </div>
          </div>
        </section>

        <section class="stacking" id="how-it-works">
          <div class="stacking-copy">
            <h2>How It Works</h2>
            <p>
              polycss loads OBJ, glTF, and GLB mesh files. Each triangle becomes
              a DOM element positioned with <code>transform: matrix3d(...)</code>.
              UV-textured triangles are packed into generated atlas sprites with
              CSS background positioning. The browser's compositor handles the
              3D layering.
            </p>
            <p>
              The rendered scene is a tree of standard DOM elements — no shadow
              DOM, no WebGL context, no canvas-as-the-whole-scene. Every polygon
              is individually addressable: attach click handlers, apply CSS
              classes, animate with CSS transitions.
            </p>
            <p class="stacking-actions" style="margin: 0">
              <a class="btn ghost" href="/quickstart">View Usage Guidelines &raquo;</a>
            </p>
          </div>
          <div class="stacking-media">
            <div style="background:#090b10;height:350px;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#475569;font-family:monospace;font-size:13px;">
              mesh demo — Phase 8
            </div>
          </div>
        </section>

        <section class="getting-started" id="getting-started">
          <header class="getting-header">
            <div>
              <h2>Hello World!</h2>
            </div>
          </header>
          <div class="getting-lede">
            <p>polycss provides custom elements (<code>&lt;poly-scene&gt;</code>, <code>&lt;poly-mesh&gt;</code>), an imperative <code>createPolyScene</code> API, and optional React / Vue bindings. Each polygon in the mesh becomes a DOM element you can style and interact with — use whichever entry point fits your stack.</p>
          </div>
          <div class="getting-grid">
            <div class="getting-content">
              <div>
                <div class="framework-tablist" role="tablist" id="framework-tablist">
                  {frameworkTabs.map((tab, i) => (
                    <button
                      class={`framework-tab${i === 0 ? ' active' : ''}`}
                      type="button"
                      role="tab"
                      aria-selected={i === 0 ? 'true' : 'false'}
                      data-tab={tab.id}
                    >
                      {tab.label}
                    </button>
                  ))}
                </div>
                {frameworkTabs.map((tab, i) => (
                  <pre
                    class={`framework-tabpanel dark-scrollbar${i === 0 ? '' : ' hidden'}`}
                    role="tabpanel"
                    data-panel={tab.id}
                  ><code class={`language-${tab.language} hljs`} set:html={tab.highlighted} /></pre>
                ))}
              </div>
              <p class="getting-actions">
                <a class="btn ghost" href="/api/headless">Browse API Reference &raquo;</a>
              </p>
            </div>
          </div>
        </section>

        <section class="gallery made-with" id="made-with">
          <div class="gallery-header">
            <h2>Gallery</h2>
          </div>
          <div class="gallery-actions">
            <a class="btn ghost" href="/gallery">View Model Gallery &raquo;</a>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    // GitHub star count
    async function fetchStars() {
      try {
        const res = await fetch("https://api.github.com/repos/LayoutitStudio/polycss");
        if (!res.ok) return;
        const json = await res.json();
        if (typeof json?.stargazers_count === "number") {
          const text = `★ ${json.stargazers_count}`;
          const elHero = document.getElementById("star-count-hero");
          if (elHero) elHero.textContent = text;
        }
      } catch (_) {}
    }
    fetchStars();

    // Hero model — loads the rock environment OBJ and mounts it with
    // createPolyScene. autoCenter pivots rotation around the mesh centroid;
    // the small RAF loop spins it slowly.
    function isMobileHeroViewport() {
      return window.matchMedia("(max-width: 760px), (pointer: coarse)").matches;
    }

    async function mountHeroModel() {
      const host = document.getElementById("hero-root");
      if (!host) return;
      try {
        const { createPolyScene, loadMesh } = await import("polycss");
        const parseResult = await loadMesh("/gallery/obj/rock1.obj", {
          mtlUrl: "/gallery/obj/rock1.mtl",
          objOptions: {
            targetSize: 40,
            defaultColor: "#8b6f47",
            excludeObjects: ["Plane"],
          },
        });

        let rotY = 45;
        const atlasScale = isMobileHeroViewport() ? 0.25 : undefined;
        const scene = createPolyScene(host, {
          rotX: 65,
          rotY,
          zoom: 0.2,
          autoCenter: true,
          interactive: true,
          perspective: false,
          atlasScale,
        });
        scene.add(parseResult);

        let last = 0;
        let paused = false;
        host.addEventListener("pointerdown", () => { paused = true; });
        function tick(now: number) {
          if (!paused) {
            const dt = last ? Math.min(50, now - last) : 0;
            rotY = (rotY + (dt / 16.67) * 0.3) % 360;
            scene.setOptions({ rotY });
          }
          last = now;
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      } catch (err) {
        console.error("hero model mount failed", err);
      }
    }
    mountHeroModel();

    // Framework tabs
    const tablist = document.getElementById("framework-tablist");
    if (tablist) {
      tablist.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest("[data-tab]") as HTMLElement | null;
        if (!btn) return;
        const id = btn.dataset.tab;
        tablist.querySelectorAll(".framework-tab").forEach((t) => {
          const isActive = (t as HTMLElement).dataset.tab === id;
          t.classList.toggle("active", isActive);
          t.setAttribute("aria-selected", String(isActive));
        });
        document.querySelectorAll(".framework-tabpanel").forEach((p) => {
          const isActive = (p as HTMLElement).dataset.panel === id;
          p.classList.toggle("hidden", !isActive);
        });
      });
    }
  </script>
</body>
</html>

<style is:global>
  :root {
    font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Ubuntu, Cantarell, "Noto Sans", sans-serif;
    background: #0b0d10;
    color: #e2e8f0;
  }
  body {
    margin: 0;
  }
  * {
    box-sizing: border-box;
  }

  /* ── Nav ─────────────────────────────────────────── */
  .docs-shell {
    display: block;
    min-height: 100vh;
    background: #0b0d10;
  }
  .docs-nav {
    position: fixed;
    z-index: 999;
    top: 0;
    right: 0;
    left: 0;
    width: 100%;
    padding: 11px 0;
    background: #0f1115;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-sizing: border-box;
    overflow-x: hidden;
    overflow-y: auto;
    font-family: Consolas, Monaco, "Andale Mono", "Ubuntu Mono", monospace;
  }
  .docs-nav nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 24px;
  }
  .docs-nav__brand,
  .nav-group,
  .docs-nav__spacer {
    min-width: 0;
  }
  .docs-nav__brand {
    justify-self: start;
    padding-left: 16px;
  }
  .docs-nav__spacer {
    justify-self: end;
    padding-right: 16px;
    font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Ubuntu, Cantarell, "Noto Sans", sans-serif;
  }
  .nav-group {
    justify-self: center;
  }
  .nav-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 4px;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 8px;
  }
  .nav-group li {
    padding: 0;
  }
  .nav-group a {
    display: block;
    padding: 0.55rem 0.7rem;
    font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Ubuntu, Cantarell, "Noto Sans", sans-serif;
    color: #94a3b8;
    opacity: 1;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    border-radius: 999px;
  }
  .nav-group a:hover {
    color: #e2e8f0;
    background: rgba(56, 189, 248, 0.14);
  }
  .nav-group a.active {
    color: #fff;
    background: rgba(56, 189, 248, 0.14);
  }

  /* ── GitHub Social ──────────────────────────────── */
  .github-social {
    display: inline-flex;
    align-items: stretch;
    border-radius: 6px;
    background: #f6f8fa;
    border: 1px solid #d0d7de;
    color: #24292f;
    text-decoration: none;
    font-weight: 600;
    user-select: none;
    white-space: nowrap;
  }
  .github-social:hover,
  .github-social:focus-visible {
    background: #ddd;
    border-color: #afb8c1;
    color: #1f2328;
  }
  .github-social__main {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-right: 1px solid #d0d7de;
    font-size: 14px;
  }
  .github-social__icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  .github-social__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    padding: 8px 10px;
    background: #ffffff;
    border-radius: 0 6px 6px 0;
    color: #24292f;
    font-size: 14px;
  }

  /* ── Content ────────────────────────────────────── */
  .docs-content {
    padding-top: 72px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    min-height: calc(100vh - 72px);
  }

  /* ── Home ───────────────────────────────────────── */
  .home {
    max-width: 1100px;
    margin: 20px auto;
  }

  /* ── Hero ───────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 20px;
    align-items: center;
    background: linear-gradient(135deg, #050a13, #0f1e31);
    border-radius: 12px;
    border: 1px solid rgba(56, 189, 248, 0.25);
    padding: 0px 40px;
    position: relative;
  }
  .hero-canvas,
  .hero-copy {
    padding: 30px 0px;
  }
  .hero-copy h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin: 5px 0 12px;
    font-family: Consolas, Monaco, "Andale Mono", "Ubuntu Mono", monospace;
    color: #7dd3fc;
  }
  .hero-copy p {
    color: #ccc;
    line-height: 1.6;
    font-size: 18px;
    margin: 0 0 16px;
    padding-right: 5px;
  }
  .hero-copy hr {
    border: 0;
    border-top: 0px solid rgba(56, 189, 248, 0.25);
    padding-top: 10px;
    margin-top: 10px;
  }
  .cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-canvas {
    min-height: 320px;
    margin-top: 10px;
    height: 100%;
    /* createPolyScene mounts its 0×0 scene anchor at top:50%/left:50% —
       requires the host to be a positioned ancestor or it'll snap to the
       document root. */
    position: relative;
  }
  .install-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
    position: absolute;
    top: 42px;
    right: 20px;
    flex-direction: column;
  }
  .install-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
    opacity: 0.5;
  }

  /* ── Buttons ────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 18px;
    line-height: 1.2;
    color: #e2e8f0;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0);
    background: rgba(255, 255, 255, 0.08);
    box-sizing: border-box;
    transition: background 150ms ease, color 150ms ease;
    cursor: pointer;
  }
  .btn:hover {
    text-decoration: none;
    background: #333;
    color: #f8fafc;
  }
  .btn.ghost {
    background: #222;
    border-color: rgba(255, 255, 255, 0);
    color: #e2e8f0;
  }
  .btn.ghost:hover {
    background: #333;
    color: #f8fafc;
  }

  /* ── Install ────────────────────────────────────── */
  .install {
    margin-top: 30px;
    background: #11141a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 28px;
    padding-bottom: 10px;
  }
  .install-header h2 {
    margin: 0;
  }
  .install-list {
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 20px;
  }
  .install-row {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 18px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    flex-wrap: wrap;
  }
  .install-row:first-child {
    border-top: none;
    padding-top: 0;
  }
  .install-label {
    margin: 0;
    min-width: 160px;
    font-weight: 600;
    color: #cbd5e1;
  }
  .install-content {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    align-items: flex-start;
    min-width: 0;
  }
  .install-content code {
    background: #050709;
    border: 0 !important;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 14px;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }
  .install-content pre {
    margin: 0;
    border-radius: 6px;
    padding: 10px;
    background: #050709;
    overflow: auto;
    flex: 1 1 260px;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }

  /* ── How It Works ───────────────────────────────── */
  .stacking {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 28px;
    align-items: center;
    margin-top: 30px;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 28px;
  }
  .stacking-copy h2 {
    margin: 0 0 20px;
  }
  .stacking-copy p {
    color: #94a3b8;
    line-height: 1.6;
    font-size: 18px;
    margin: 0 0 16px;
    padding-right: 5px;
  }
  .stacking-media {
    width: 100%;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    height: 350px;
  }

  /* ── Getting Started ────────────────────────────── */
  .getting-started {
    margin-top: 30px;
    background: #11141a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 28px;
    font-size: 18px;
  }
  .getting-header h2 {
    margin: 0;
  }
  .getting-lede {
    margin-top: 16px;
