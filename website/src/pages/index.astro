---
import hljs from "highlight.js/lib/core";
import xml from "highlight.js/lib/languages/xml";
import javascript from "highlight.js/lib/languages/javascript";
import typescript from "highlight.js/lib/languages/typescript";

hljs.registerLanguage("html", xml);
hljs.registerLanguage("xml", xml);
hljs.registerLanguage("javascript", javascript);
hljs.registerLanguage("tsx", typescript);
hljs.registerLanguage("vue", xml);

import DocsHeader from "../components/DocsHeader.astro";
import GlyphcssDemo from "../components/GlyphcssDemo.astro";
import AsciiArt from "../components/AsciiArt.astro";

function highlight(code: string, lang: string): string {
  return hljs.highlight(code, { language: lang }).value;
}

const title = "glyphcss: ASCII polygon-mesh renderer for the DOM";
const description = "Render textured 3D meshes into a character grid. Single <pre> + sparse DOM hit layer — inspect every hotspot in DevTools, attach onClick to any 3D anchor, with zero polygon-per-node overhead.";
const siteUrl = "https://glyphcss.com";

const frameworkTabs = [
  {
    id: "vanilla",
    label: "vanilla js",
    language: "html",
    code: `<script type="module" src="https://esm.sh/glyphcss/elements"></script>

<glyphcss-scene rot-x="0.4" geometry="cuboctahedron">
  <glyphcss-orbit-controls drag wheel></glyphcss-orbit-controls>
  <glyphcss-hotspot at="0,1,0"></glyphcss-hotspot>
</glyphcss-scene>`,
  },
  {
    id: "react",
    label: "React",
    language: "tsx",
    code: `import { GlyphcssCamera, GlyphcssScene, GlyphcssOrbitControls, GlyphcssMesh, GlyphcssHotspot } from "@glyphcss/react";

export function App() {
  return (
    <GlyphcssCamera rotX={0.4} scale={0.32}>
      <GlyphcssScene>
        <GlyphcssOrbitControls drag wheel />
        <GlyphcssMesh src="/cottage.glb">
          <GlyphcssHotspot at={[0, 1.2, 0]} onClick={() => alert("roof")} />
        </GlyphcssMesh>
      </GlyphcssScene>
    </GlyphcssCamera>
  );
}`,
  },
  {
    id: "vue",
    label: "Vue",
    language: "vue",
    code: `<template>
  <GlyphcssCamera :rot-x="0.4" :scale="0.32">
    <GlyphcssScene>
      <GlyphcssOrbitControls drag wheel />
      <GlyphcssMesh src="/cottage.glb">
        <GlyphcssHotspot :at="[0, 1.2, 0]" @click="onRoof" />
      </GlyphcssMesh>
    </GlyphcssScene>
  </GlyphcssCamera>
</template>
<script setup lang="ts">
import { GlyphcssCamera, GlyphcssScene, GlyphcssOrbitControls, GlyphcssMesh, GlyphcssHotspot } from "@glyphcss/vue";
function onRoof() { alert("roof"); }
</script>`,
  },
].map(tab => ({
  ...tab,
  highlighted: highlight(tab.code, tab.language),
}));

const installCmds = [
  "npm install glyphcss",
  "npm install @glyphcss/react",
  "npm install @glyphcss/vue",
].map(cmd => ({ code: cmd, highlighted: highlight(cmd, "javascript") }));

const ldJson = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "glyphcss",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description,
  url: siteUrl,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  sameAs: ["https://github.com/apresmoi/glyphcss"],
  publisher: { "@type": "Organization", name: "glyphcss", url: siteUrl },
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" />
  <style>
    html { background: #0b0d10; color: #e2e8f0; }
    body { margin: 0; }
  </style>
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
</head>
<body>
  <div class="docs-shell">
    <DocsHeader />

    <main class="docs-content">
      <div class="home">
        <section class="hero hero--ascii" id="hero">
          <div class="hero-scene" aria-hidden="true">
            <GlyphcssDemo id="hero-demo"
              mesh="/gallery/glb/apple.glb"
              defaults={JSON.stringify({ scale: 0.2625, distance: 100000, rotX: 1.299, rotY: 5.264, duration: 14, renderMode: 'solid' })}
              noCode
              noControls
            />
          </div>
          <div class="hero-overlay">
            <h1 class="hero-wordmark" aria-label="glyphcss">
              <span class="wm-a">glyph</span><span class="wm-b">css</span>
            </h1>
            <p class="hero-tag">
              <span class="hero-prompt">&gt;</span>
              Render textured 3D meshes in the DOM with ASCII.
              No WebGL. No <code>&lt;canvas&gt;</code>. Each scene is a single
              <code>&lt;pre&gt;</code> you can inspect, hover, and click.
            </p>
            <p class="hero-tag">
              <span class="hero-prompt">&gt;</span>
              Supports OBJ, glTF, GLB, and MagicaVoxel VOX —
              including UV textures and material colors.
              Works with vanilla JS, React, and Vue.
            </p>
            <AsciiArt
              module="ascii-diagrams/heroRule"
              factory="heroRule"
              className="hero-rule"
              ariaLabel="divider"
            />
            <div class="hero-actions">
              <a
                class="hero-btn"
                href="https://github.com/apresmoi/glyphcss"
                target="_blank"
                rel="noopener noreferrer"
              >
                [ View on GitHub ★ <span id="star-count-hero">…</span> ]
              </a>
              <a class="hero-btn ghost" href="/gallery">[ Browse gallery ]</a>
            </div>
            <div class="hero-runtimes">
              <span>runtimes:</span>
              <span class="hero-chip">vanilla&nbsp;js</span>
              <span class="hero-chip">react</span>
              <span class="hero-chip">vue</span>
            </div>
          </div>
        </section>

        <section class="install" id="install">
          <div class="term-section-rule">
            <span class="term-section-label">[ INSTALLATION ]</span>
          </div>
          <div class="install-list">
            <div class="install-row">
              <p class="install-label">
                <span class="term-dim">┌─</span> package managers <span class="term-dim">─┐</span>
              </p>
              <div class="install-content">
                {installCmds.map(cmd => (
                  <div class="term-cmd-frame">
                    <div class="term-cmd-bar"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span><span class="term-cmd-title">terminal</span></div>
                    <pre class="dark-scrollbar term-cmd-pre"><span class="term-prompt">$</span> <code class="language-bash hljs" set:html={cmd.highlighted} /></pre>
                  </div>
                ))}
              </div>
            </div>
            <div class="install-row">
              <p class="install-label">
                <span class="term-dim">┌─</span> cdn <span class="term-dim">─┐</span>
              </p>
              <div class="install-content">
                <div class="term-cmd-frame">
                  <div class="term-cmd-bar"><span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span><span class="term-cmd-title">index.html</span></div>
                  <pre class="dark-scrollbar term-cmd-pre"><code class="language-html hljs" set:html={highlight('<script type="module" src="https://esm.sh/glyphcss/elements"></script>', "html")} /></pre>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="stacking" id="how-it-works">
          <div class="term-section-rule">
            <span class="term-section-label">[ HOW IT WORKS ]</span>
          </div>
          <div class="stacking-copy">
            <div class="stacking-diagram" aria-hidden="true">
              <AsciiArt
                module="ascii-diagrams/howItWorks"
                factory="howItWorksDiagram"
                className="stacking-art"
                minCols={48}
                ariaLabel="glyphcss render pipeline diagram"
              />
            </div>
            <p>
              <span class="term-prompt-inline">&gt;</span>
              glyphcss loads OBJ, glTF, GLB, and VOX mesh files. Each scene becomes
              a single <code>&lt;pre&gt;</code> containing N pre-baked rotation
              frames stacked vertically, animated by CSS <code>steps(N)</code>.
              JavaScript runs once at scene init and again only when the user
              drags / zooms — never per frame.
            </p>
            <p>
              <span class="term-prompt-inline">&gt;</span>
              Interactivity is opt-in and sparse: drop a <code>&lt;GlyphcssHotspot&gt;</code>
              at any 3D anchor and glyphcss emits one absolutely-positioned
              <code>&lt;div&gt;</code> over the projected cell. Real DOM events,
              real <code>:hover</code> styles, real <code>role="button"</code>
              accessibility — without one DOM node per polygon.
            </p>
            <p class="stacking-actions" style="margin: 0">
              <a class="term-link-btn" href="/core-concepts">[ → core concepts ]</a>
            </p>
          </div>
        </section>

        <section class="getting-started" id="getting-started">
          <div class="term-section-rule">
            <span class="term-section-label">[ HELLO WORLD ]</span>
          </div>
          <div class="getting-lede">
            <p>
              <span class="term-prompt-inline">&gt;</span>
              glyphcss provides custom elements (<code>&lt;glyphcss-scene&gt;</code>, <code>&lt;glyphcss-mesh&gt;</code>),
              an imperative <code>createGlyphcssScene</code> API, and optional React / Vue bindings.
              Use whichever entry point fits your stack.
            </p>
          </div>
          <div class="getting-grid">
            <div class="getting-content">
              <div class="term-editor-shell">
                <div class="term-editor-bar">
                  <span class="term-dot r"></span><span class="term-dot y"></span><span class="term-dot g"></span>
                  <span class="term-editor-path">~/project/</span>
                  <div class="framework-tablist" role="tablist" id="framework-tablist">
                    {frameworkTabs.map((tab, i) => (
                      <button
                        class={`framework-tab${i === 0 ? ' active' : ''}`}
                        type="button"
                        role="tab"
                        aria-selected={i === 0 ? 'true' : 'false'}
                        data-tab={tab.id}
                      >
                        {tab.label}
                      </button>
                    ))}
                  </div>
                </div>
                {frameworkTabs.map((tab, i) => (
                  <pre
                    class={`framework-tabpanel dark-scrollbar${i === 0 ? '' : ' hidden'}`}
                    role="tabpanel"
                    data-panel={tab.id}
                  ><code class={`language-${tab.language} hljs`} set:html={tab.highlighted} /></pre>
                ))}
              </div>
              <p class="getting-actions">
                <a class="term-link-btn" href="/api/headless">[ → api reference ]</a>
              </p>
            </div>
          </div>
        </section>

        <footer class="term-footer">
          <div class="term-footer-bar">
            <span class="term-footer-seg">[ glyphcss v1.0 ]</span>
            <span class="term-footer-sep">──</span>
            <span class="term-footer-seg">[ MIT ]</span>
            <span class="term-footer-sep">──</span>
            <a class="term-footer-seg term-footer-link" href="https://github.com/apresmoi/glyphcss" target="_blank" rel="noopener noreferrer">[ github.com/apresmoi/glyphcss ]</a>
            <span class="term-footer-sep">──</span>
            <span class="term-footer-seg">[ uptime: ∞ ]</span>
          </div>
        </footer>
      </div>
    </main>
  </div>

  <script>
    async function fetchStars() {
      try {
        const res = await fetch("https://api.github.com/repos/glyphcss/glyphcss");
        if (!res.ok) return;
        const json = await res.json();
        if (typeof json?.stargazers_count === "number") {
          const elHero = document.getElementById("star-count-hero");
          if (elHero) elHero.textContent = `★ ${json.stargazers_count}`;
        }
      } catch (_) {}
    }
    fetchStars();

    const tablist = document.getElementById("framework-tablist");
    if (tablist) {
      tablist.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest("[data-tab]") as HTMLElement | null;
        if (!btn) return;
        const id = btn.dataset.tab;
        tablist.querySelectorAll(".framework-tab").forEach((t) => {
          const isActive = (t as HTMLElement).dataset.tab === id;
          t.classList.toggle("active", isActive);
          t.setAttribute("aria-selected", String(isActive));
        });
        document.querySelectorAll(".framework-tabpanel").forEach((p) => {
          const isActive = (p as HTMLElement).dataset.panel === id;
          p.classList.toggle("hidden", !isActive);
        });
      });
    }
  </script>
</body>
</html>

<style is:global>
  :root {
    font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Ubuntu, Cantarell, "Noto Sans", sans-serif;
    background: #0b0d10;
    color: #e2e8f0;
  }
  body {
    margin: 0;
  }
  * {
    box-sizing: border-box;
  }

  /* ── Nav ─────────────────────────────────────────── */
  .docs-shell {
    display: block;
    min-height: 100vh;
    background: #0b0d10;
  }

  /* Landing's header is in-flow (scrolls with content), unlike the docs/gallery
     pages where DocsHeader is position:fixed. Override the fixed positioning. */
  .docs-shell > .header {
    position: static;
    inset-block-start: auto;
    inset-inline-start: auto;
    width: auto;
    background-color: #0f1115;
  }

  /* ── GitHub Social ──────────────────────────────── */
  .github-social {
    display: inline-flex;
    align-items: stretch;
    border-radius: 6px;
    background: #f6f8fa;
    border: 1px solid #d0d7de;
    color: #24292f;
    text-decoration: none;
    font-weight: 600;
    user-select: none;
    white-space: nowrap;
  }
  .github-social:hover,
  .github-social:focus-visible {
    background: #ddd;
    border-color: #afb8c1;
    color: #1f2328;
  }
  .github-social__main {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-right: 1px solid #d0d7de;
    font-size: 14px;
  }
  .github-social__icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  .github-social__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    padding: 8px 10px;
    background: #ffffff;
    border-radius: 0 6px 6px 0;
    color: #24292f;
    font-size: 14px;
  }

  /* ── Content ────────────────────────────────────── */
  .docs-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Home ───────────────────────────────────────── */
  .home {
    width: 100%;
    max-width: 1100px;
    margin: 20px auto;
    /* The hero scene strip is intrinsically ~1100px wide, so without
       width: 100% + min-width: 0 the flexbox algorithm sizes .home to its
       min-content (1100px) and the page overflows horizontally — pushing
       section rules and code blocks past the viewport on narrow screens.
       overflow-x: clip lets the strip get cropped instead of widening us. */
    min-width: 0;
    overflow-x: clip;
    box-sizing: border-box;
  }

  /* ── Hero ───────────────────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 20px;
    align-items: center;
    background: linear-gradient(135deg, #050a13, #0f1e31);
    border-radius: 12px;
    border: 1px solid rgba(56, 189, 248, 0.25);
    padding: 0px 40px;
    position: relative;
    /* Locked to glyphcss's hero-card height (~390px). */
    height: 389.99px;
    min-height: 389.99px;
    box-sizing: border-box;
  }

  /* ── ASCII-art hero (meta: the visual IS a glyphcss scene) ──────── */
  /* Mobile-first: text stacked on top, scene below. Side-by-side kicks
     in at ≥768px (see media query below). The scene used to sit behind
     the text via position: absolute; that read as "background image of
     an apple" which isn't the framing we want. */
  .hero--ascii {
    display: grid;
    /* minmax(0, 1fr) — not bare 1fr — so the track shrinks below the demo's
       min-content (the rasterized strip's intrinsic width with white-space:
       pre). Bare 1fr resolves to minmax(auto, 1fr), and auto-min inflates the
       track to fit the strip even when min-width:0 is set on every grid item
       in the chain. */
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      "overlay"
      "scene";
    height: auto;
    min-height: 0;
    padding: 0;
    overflow: hidden;
    background: radial-gradient(circle at 30% 20%, #0c1726 0%, #050609 60%, #02030a 100%);
    border-color: rgba(255, 232, 184, 0.18);
    font-family: ui-monospace, "JetBrains Mono", "SF Mono", "Menlo", monospace;
  }
  .hero--ascii .hero-scene {
    grid-area: scene;
    position: relative;
    height: clamp(240px, 40vw, 360px);
    overflow: hidden;
    min-width: 0;
  }
  .hero--ascii .hero-scene > .glyphcss-demo {
    width: 100%;
    height: 100%;
    margin: 0;
    background: transparent;
    border: none;
    border-radius: 0;
  }
  .hero--ascii .hero-scene .glyphcss-demo__viewer,
  .hero--ascii .hero-scene .glyphcss-demo__canvas,
  .hero--ascii .hero-scene .glyphcss-demo__scene-host {
    width: 100%;
    height: 100%;
    min-height: 0;
    background: transparent !important;
  }

  .hero--ascii .hero-overlay {
    grid-area: overlay;
    padding: clamp(28px, 6vw, 48px) clamp(20px, 5vw, 48px);
    color: rgba(255, 232, 184, 0.94);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .hero--ascii {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      grid-template-areas: "overlay scene";
      align-items: center;
      min-height: clamp(420px, 56vh, 560px);
    }
    .hero--ascii .hero-scene {
      height: 100%;
      min-height: clamp(420px, 56vh, 560px);
    }
  }

  /* same minmax(0, ...) guard for the demo's inner grid — without it, the
     strip's white-space: pre min-content leaks back through here too. */
  .hero-wordmark {
    margin: 0 0 14px;
    padding: 0;
    font-family: ui-monospace, "JetBrains Mono", "SF Mono", "Menlo", monospace;
    font-size: clamp(48px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -2px;
    font-weight: 900;
  }
  .hero-wordmark .wm-a {
    color: #f97316;
    text-shadow: 0 0 18px rgba(249, 115, 22, 0.6), 0 0 4px #000;
  }
  .hero-wordmark .wm-b {
    color: #38bdf8;
    text-shadow: 0 0 18px rgba(56, 189, 248, 0.6), 0 0 4px #000;
  }
  .hero-tag {
    margin: 6px 0;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(226, 232, 240, 0.92);
  }
  .hero-prompt {
    color: rgba(56, 189, 248, 0.9);
    margin-right: 8px;
  }
  .hero-tag code {
    font-family: ui-monospace, monospace;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.25);
    padding: 0 4px;
    border-radius: 2px;
    color: #7dd3fc;
    font-size: 0.92em;
  }
  .hero-rule {
    width: 100%;
    margin: 14px 0 12px;
    color: rgba(255, 232, 184, 0.35);
    font-family: ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .hero-btn {
    display: inline-block;
    padding: 7px 16px;
    font-family: ui-monospace, monospace;
    font-size: 13px;
    color: rgba(255, 232, 184, 0.94);
    background: rgba(15, 17, 21, 0.55);
    border: 1px solid rgba(255, 232, 184, 0.28);
    text-decoration: none;
    transition: background 100ms, border-color 100ms, color 100ms;
  }
  .hero-btn:hover {
    background: rgba(56, 189, 248, 0.15);
    border-color: rgba(56, 189, 248, 0.55);
    color: #e2e8f0;
  }
  .hero-btn.ghost {
    border-style: dashed;
  }
  .hero-runtimes {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    row-gap: 6px;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    color: rgba(255, 232, 184, 0.55);
  }
  .hero-chip {
    padding: 2px 10px;
    border: 1px solid rgba(255, 232, 184, 0.25);
    color: rgba(255, 232, 184, 0.85);
  }
  .hero-canvas,
  .hero-copy {
    padding: 30px 0px;
  }
  .hero-copy h1 {
    font-size: 4.5rem;
    line-height: 1;
    margin: 5px 0 12px;
    font-family: Consolas, Monaco, "Andale Mono", "Ubuntu Mono", monospace;
    font-weight: 900;
    letter-spacing: -2px;
  }
  .wm-a {
    color: #f97316;
    text-shadow: 0 0 12px rgba(249, 115, 22, 0.45);
  }
  .wm-b {
    color: #38bdf8;
    text-shadow: 0 0 12px rgba(56, 189, 248, 0.45);
  }
  .hero-copy p {
    color: #ccc;
    line-height: 1.6;
    font-size: 18px;
    margin: 0 0 16px;
    padding-right: 5px;
  }
  .hero-copy code {
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    background: rgba(56, 189, 248, 0.12);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 0.92em;
    color: #7dd3fc;
  }
  .hero-copy hr {
    border: 0;
    border-top: 0px solid rgba(56, 189, 248, 0.25);
    padding-top: 10px;
    margin-top: 10px;
  }
  .cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-canvas {
    /* Fills the hero card vertically (which is now locked to 389.99px). */
    height: 100%;
    position: relative;
  }
  /* Make the GlyphcssDemo inside the hero fill the canvas column. */
  .hero-canvas > .glyphcss-demo {
    height: 100%;
    margin: 0;
    /* Remove the dark box — hero demo should be transparent */
    background: transparent;
    border: none;
    border-radius: 0;
  }
  .hero-canvas .glyphcss-demo__viewer,
  .hero-canvas .glyphcss-demo__canvas,
  .hero-canvas .glyphcss-demo__scene-host {
    height: 100%;
