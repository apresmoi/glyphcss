---
import DebugWorkbench from '../debug/DebugWorkbench.tsx';
import DocsHeader from '../components/DocsHeader.astro';
import '../styles/custom.css';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Gallery</title>
  </head>
  <body>
    <div class="page">
      <DocsHeader />
      <div class="debug-page-shell">
        <DebugWorkbench client:only="react" />
      </div>
    </div>
  </body>
  <style>
    :global(:root) {
      --sl-nav-height: 72px;
    }

    :global(html, body) {
      margin: 0;
      background: #0a0b0d;
      color: #e8edf2;
    }

    :global(body) {
      min-height: 100vh;
      overflow: hidden;
    }

    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      /* DocsHeader is position:fixed and out of flow; push shell content down */
      padding-top: 72px;
    }

    .debug-page-shell {
      flex: 1 1 auto;
      min-height: 0;
      height: calc(100vh - 72px);
    }
    :global(.dn-root) {
      width: 100%;
      height: 100%;
    }
  </style>
</html>
