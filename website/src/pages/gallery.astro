---
const SITE_URL = "https://polycss.com";
// Reusing the legacy voxcss social card until a polycss-specific image lands.
const OG_IMAGE = `${SITE_URL}/voxcss-intro.png`;
const SITE_NAME = "polycss";

const title = "polycss Gallery — polygon mesh models";
const description =
  "Browse 3D mesh models rendered with polycss: OBJ, GLB, and glTF files rendered as DOM elements with UV textures.";
const url = `${SITE_URL}/gallery`;

const ldJson = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url,
  image: OG_IMAGE,
  about: {
    "@type": "SoftwareApplication",
    name: SITE_NAME,
    url: SITE_URL,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
    url: SITE_URL,
  },
};

// Gallery entries — mesh files from public/gallery/
const MESH_ENTRIES = [
  { id: "cottage", label: "Cottage", format: "OBJ", src: "/gallery/obj/cottage.obj", category: "Architecture" },
  { id: "church", label: "Church", format: "OBJ", src: "/gallery/obj/church.obj", category: "Architecture" },
  { id: "castle", label: "Castle", format: "OBJ", src: "/gallery/obj/castle.obj", category: "Architecture" },
  { id: "coliseum", label: "Coliseum", format: "OBJ", src: "/gallery/obj/coliseum.obj", category: "Architecture" },
  { id: "ranger", label: "Ranger", format: "GLB", src: "/gallery/glb/ranger.glb", category: "Characters" },
  { id: "insurgent", label: "Insurgent", format: "GLTF", src: "/gallery/glb/insurgent.gltf", category: "Characters" },
  { id: "chicken", label: "Chicken", format: "OBJ", src: "/gallery/obj/chicken.obj", category: "Characters" },
  { id: "avocado", label: "Avocado", format: "OBJ", src: "/gallery/obj/avocado.obj", category: "Objects" },
  { id: "sting", label: "Sting Sword", format: "OBJ", src: "/gallery/obj/sting.obj", category: "Objects" },
  { id: "teapot", label: "Teapot", format: "OBJ", src: "/gallery/obj/teapot.obj", category: "Objects" },
  { id: "wheelbarrow", label: "Wheelbarrow", format: "OBJ", src: "/gallery/obj/wheelbarrow.obj", category: "Objects" },
  { id: "rock1", label: "Rock (UV)", format: "OBJ", src: "/gallery/obj/rock1.obj", category: "Environment" },
  { id: "tree", label: "Tree", format: "GLB", src: "/gallery/glb/tree.glb", category: "Environment" },
  { id: "saucer", label: "Flying Saucer", format: "OBJ", src: "/gallery/obj/saucer.obj", category: "Vehicles" },
  { id: "apoc-car", label: "Apocalypse Car", format: "GLB", src: "/gallery/glb/apocalypse/car.glb", category: "Vehicles" },
  { id: "apoc-barrel", label: "Barrel", format: "GLB", src: "/gallery/glb/apocalypse/barrel.glb", category: "Objects" },
  { id: "apoc-wall", label: "Wall", format: "GLB", src: "/gallery/glb/apocalypse/wall_1.glb", category: "Architecture" },
  { id: "apoc-spike", label: "Spike Barricade", format: "GLB", src: "/gallery/glb/apocalypse/wooden_spike_barricade.glb", category: "Objects" },
];

const categories = [...new Set(MESH_ENTRIES.map(e => e.category))];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <link rel="canonical" href={url} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  <style is:global>
    html { background: #0b0d10; color: #e2e8f0; }
    body { margin: 0; font-family: "Inter", system-ui, sans-serif; }
    *, *::before, *::after { box-sizing: border-box; }

    .docs-nav {
      position: fixed;
      z-index: 999;
      top: 0;
      left: 0;
      right: 0;
      padding: 11px 0;
      background: #0f1115;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-family: Consolas, Monaco, "Andale Mono", monospace;
    }
    .docs-nav nav {
      display: grid;
      grid-template-columns: minmax(0,1fr) auto minmax(0,1fr);
      align-items: center;
      gap: 24px;
    }
    .docs-nav__brand { justify-self: start; padding-left: 16px; }
    .docs-nav__brand a { color: #7dd3fc; text-decoration: none; font-size: 18px; font-family: monospace; font-weight: bold; }
    .docs-nav__spacer { justify-self: end; padding-right: 16px; }
    .nav-group { justify-self: center; }
    .nav-group ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 44px; }
    .nav-group a { display: block; padding: 6px 0; color: #cbd5f5; opacity: 0.7; text-decoration: none; font-size: 15px; }
    .nav-group a:hover { opacity: 1; font-weight: bold; }
    .nav-group a.active { opacity: 1; color: #fff; font-weight: bold; text-decoration: underline; }

    .page {
      padding-top: 72px;
      max-width: 1100px;
      margin: 0 auto;
      padding-left: 24px;
      padding-right: 24px;
    }
    .page-header { padding: 32px 0 16px; }
    .page-header h1 { margin: 0 0 8px; font-size: 2rem; }
    .page-header p { margin: 0; color: #94a3b8; font-size: 16px; }

    .category { margin-top: 32px; }
    .category h2 { margin: 0 0 16px; font-size: 1.1rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }

    .mesh-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
    }
    .mesh-card {
      background: #11141a;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .mesh-card__label { font-weight: 600; font-size: 15px; color: #e2e8f0; }
    .mesh-card__meta { font-size: 12px; color: #64748b; font-family: monospace; }
    .mesh-card__src { font-size: 11px; color: #334155; font-family: monospace; word-break: break-all; }

    .notice {
      margin-top: 40px;
      padding: 20px 24px;
      background: #0f172a;
      border: 1px solid rgba(56,189,248,0.2);
      border-radius: 10px;
      color: #94a3b8;
      font-size: 14px;
      line-height: 1.6;
    }
    .notice a { color: #7dd3fc; }

    @media (max-width: 1024px) {
      .docs-nav { position: static; }
      .page { padding-top: 16px; }
      .docs-nav nav { grid-template-columns: 1fr auto; }
      .nav-group { grid-column: 1/-1; }
      .nav-group ul { gap: 16px; flex-wrap: nowrap; overflow-x: auto; }
    }
  </style>
</head>
<body>
  <div class="docs-nav">
    <nav>
      <div class="docs-nav__brand">
        <a href="/">polycss</a>
      </div>
      <div class="nav-group">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/quickstart">Usage</a></li>
          <li><a href="/api/headless">API</a></li>
          <li><a href="/gallery" class="active">Gallery</a></li>
        </ul>
      </div>
      <div class="docs-nav__spacer">
        <a href="https://github.com/LayoutitStudio/polycss" target="_blank" rel="noopener noreferrer" style="color:#7dd3fc;text-decoration:none;font-size:13px;font-family:monospace;">GitHub</a>
      </div>
    </nav>
  </div>

  <div class="page">
    <header class="page-header">
      <h1>Model Gallery</h1>
      <p>OBJ, GLB, and glTF meshes that ship with the polycss debug viewer. Each renders as DOM elements via <code>PolyMesh</code>.</p>
    </header>

    <div class="notice">
      The interactive mesh viewer lives at <a href="/debug/meshes">/debug/meshes</a>. Load any model below and rotate it in real time.
    </div>

    {categories.map(cat => (
      <div class="category">
        <h2>{cat}</h2>
        <div class="mesh-grid">
          {MESH_ENTRIES.filter(e => e.category === cat).map(entry => (
            <div class="mesh-card">
              <div class="mesh-card__label">{entry.label}</div>
              <div class="mesh-card__meta">{entry.format}</div>
              <div class="mesh-card__src">{entry.src}</div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</body>
</html>
