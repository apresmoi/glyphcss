---
import fs from 'fs';
import path from 'path';

const SITE_URL = "https://polycss.com";
const OG_IMAGE = `${SITE_URL}/voxcss-intro.png`;
const SITE_NAME = "polycss";

const galleryDir = path.resolve(process.cwd(), 'public/gallery');
const objDir = path.join(galleryDir, 'obj');

let triangleFiles: string[] = [];
let objFiles: { name: string; hasMtl: boolean }[] = [];

try {
  // Legacy polygon JSONs remain as a fallback for clean checkouts where the
  // OBJ fixture folder is absent.
  triangleFiles = fs.readdirSync(galleryDir)
    .filter(f => f.endsWith('.json')
      && f !== 'vox-manifest.json'
      && !f.endsWith('-smooth.json'))
    .map(f => f.replace(/\.json$/, ''));
} catch {
  // Gallery assets not present (clean checkout) — page still renders, models load at runtime
}

try {
  const entries = fs.readdirSync(objDir);
  const mtlNames = new Set(
    entries
      .filter(f => f.toLowerCase().endsWith('.mtl'))
      .map(f => f.replace(/\.mtl$/i, ''))
  );
  objFiles = entries
    .filter(f => f.toLowerCase().endsWith('.obj'))
    .map(f => {
      const name = f.replace(/\.obj$/i, '');
      return { name, hasMtl: mtlNames.has(name) };
    })
    .sort((a, b) => a.name.localeCompare(b.name));
} catch {
  // No obj/ subdir — gallery still works with triangle JSONs only
}

const title = "polycss Gallery — CSS polygon mesh models";
const description =
  "Browse downloadable polycss polygon-mesh scenes used in the docs: apples, characters, objects, and more rendered with pure CSS 3D transforms.";
const url = `${SITE_URL}/gallery`;

const ldJson = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url,
  image: OG_IMAGE,
  about: {
    "@type": "SoftwareApplication",
    name: SITE_NAME,
    url: SITE_URL,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
    url: SITE_URL,
  },
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <link rel="canonical" href={url} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  <style is:global>
    html { background: #0b0d10; color: #e2e8f0; }
    body { margin: 0; }
  </style>
</head>
<body>
  <div class="docs-shell">
    <aside class="docs-nav">
      <nav>
        <div class="docs-nav__brand">
          <a href="/" class="docs-nav__logo" aria-label="polycss home">
            <img class="docs-nav__logo-img" src="/voxisologo.png" alt="polycss" />
          </a>
        </div>
        <div class="nav-group">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/quickstart">Usage</a></li>
            <li><a href="/api/headless"><span class="nav-label"><span class="nav-label__short">API</span><span class="nav-label__long"> Reference</span></span></a></li>
            <li><a href="/gallery" class="active">Gallery</a></li>
          </ul>
        </div>
        <div class="docs-nav__spacer">
          <a
            class="github-social github-social--compact"
            href="https://github.com/LayoutitStudio/polycss"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View polycss on GitHub"
          >
            <span class="github-social__main">
              <svg class="github-social__icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
              </svg>
              <span>GitHub</span>
            </span>
            <span class="github-social__count" id="star-count-nav">&#9733; &hellip;</span>
          </a>
        </div>
      </nav>
    </aside>

    <main class="docs-content docs-content--gallery">
      <div class="gallery-page" id="gallery-page">
        <section class="viewer-panel card">
          <div class="viewer-canvas" id="viewer-root">
            <div class="viewer-state viewer-loading" id="viewer-loading" style="display:none">Loading&hellip;</div>
            <div class="viewer-state viewer-error" id="viewer-error" style="display:none"></div>
            <div class="viewer-stats" id="viewer-stats"></div>
          </div>
        </section>

        <aside class="models-sidebar" aria-label="Models">
          <div class="models-sidebar__body dark-scrollbar">
            <div class="models-sidebar__header">
              <input
                class="model-search models-sidebar__search"
                type="search"
                placeholder="Search models"
                id="model-search"
                autocomplete="off"
              />
              <button type="button" class="control-btn control-btn--primary" id="btn-random-sidebar">
                Load Random
              </button>
            </div>

            <div class="model-tree dark-scrollbar" id="model-tree"></div>
            <div class="model-empty" id="model-empty" style="display:none">No matching models</div>

            <p class="model-credit">
              Sources:
              <span>OBJ fixture models</span>
            </p>
          </div>
        </aside>

        <div class="controls-strip" aria-label="Showcase controls">
          <div class="controls-strip__row dark-scrollbar">
            <form class="controls-stack" id="controls-form">
              <button type="button" class="control-btn control-btn--primary control-btn--mobile-only" id="btn-random-mobile">
                Load Random
              </button>
              <label>
                <span class="range-heading">
                  <span>zoom</span>
                  <span class="range-value" id="zoom-value">0.20</span>
                </span>
                <input type="range" min="0.1" max="2" step="0.01" id="zoom-slider" value="0.2" />
              </label>

              <label class="switch">
                <input type="checkbox" id="animate-toggle" />
                <span>animate</span>
              </label>

              <label class="switch">
                <input type="checkbox" id="floor-toggle" />
                <span>show floor</span>
              </label>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script type="application/json" id="gallery-triangle-files" set:html={JSON.stringify(triangleFiles)} />
  <script type="application/json" id="gallery-obj-files" set:html={JSON.stringify(objFiles)} />

  <script>
    // ── Utilities ────────────────────────────────────────────────────────────

    const hashStringToUint32 = (value) => {
      const str = typeof value === "string" ? value : "";
      let hash = 2166136261;
      for (let i = 0; i < str.length; i += 1) {
        hash ^= str.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }
      return hash >>> 0;
    };

    const toToken = (value) => (typeof value === "string" ? value : "").trim();

    const humanizeToken = (token) => {
      const cleaned = toToken(token).replace(/[_-]+/g, " ");
      if (!cleaned) return "";
      return cleaned.replace(/\b[a-z]/gi, (char) => char.toUpperCase());
    };

    const OBJ_MODEL_CONFIG = {
      avocado: {
        label: "Avocado",
        category: "objects",
        options: { targetSize: 50, defaultColor: "#cccccc" },
        camera: { zoom: 0.4, rotX: 65, rotY: 45 },
      },
      castle: {
        label: "Castle",
        category: "architecture",
        options: { targetSize: 60 },
        camera: { zoom: 0.15, rotX: 66.9, rotY: 68.5 },
      },
      chicken: {
        label: "Chicken",
        category: "characters",
        options: { targetSize: 60, defaultColor: "#cccccc" },
        camera: { zoom: 0.15, rotX: 74.4, rotY: 301.6 },
      },
      coliseum: {
        label: "Coliseum",
        category: "architecture",
        options: { targetSize: 80, palette: ["#c9a876", "#a78760", "#8b6f47", "#6b5538"] },
        camera: { zoom: 0.15, rotX: 65, rotY: 45 },
      },
      cottage: {
        label: "Cottage",
        category: "architecture",
        options: {
          targetSize: 60,
          defaultColor: "#a0a0a0",
          materialTextures: { cottage_texture: "/gallery/obj/cottage-diffuse.png" },
          includeObjects: ["Cube_Cube.002"],
        },
        camera: { zoom: 0.4, rotX: 65, rotY: 45 },
      },
      rock1: {
        label: "Rock",
        category: "environment",
        options: { targetSize: 40, defaultColor: "#8b6f47", excludeObjects: ["Plane"] },
        camera: { zoom: 0.6, rotX: 65, rotY: 45 },
      },
      saucer: {
        label: "Flying Saucer",
        category: "vehicles",
        options: { targetSize: 60, defaultColor: "#94a3b8" },
        camera: { zoom: 0.2, rotX: 67, rotY: 42.3 },
      },
      sting: {
        label: "Sting Sword",
        category: "objects",
        options: {
          targetSize: 60,
          defaultColor: "#cccccc",
          materialTextures: { Sting: "/gallery/obj/sting-diffuse.png" },
        },
        camera: { zoom: 0.3, rotX: 65, rotY: 45 },
      },
      teapot: {
        label: "Teapot",
        category: "objects",
        options: { targetSize: 60, defaultColor: "#a3a3a3" },
        camera: { zoom: 0.2, rotX: 65, rotY: 45 },
      },
      wheelbarrow: {
        label: "Wheelbarrow",
        category: "objects",
        options: { targetSize: 60 },
        camera: { zoom: 0.2, rotX: 66.2, rotY: 36.1 },
      },
    };

    const createModelEntry = (entry, type = "json") => {
      const name = typeof entry === "string" ? entry : entry?.name;
      const hasMtl = typeof entry === "object" && entry ? Boolean(entry.hasMtl) : false;
      const config = type === "obj" ? OBJ_MODEL_CONFIG[name] || {} : {};
      const label = config.label || humanizeToken(name);
      const id = `${type}:${name}`;
      return {
        id,
        type,
        name,
        label,
        hasMtl,
        urlId: hashStringToUint32(id),
        legacyUrlKey: `${type}:${name}`,
      };
    };

    // ── Model data (injected at build time) ──────────────────────────────────

    const triangleFiles = JSON.parse(
      document.getElementById("gallery-triangle-files").textContent
    );
    const objFiles = JSON.parse(
      document.getElementById("gallery-obj-files").textContent
    );

    const objModels = objFiles.map((entry) => createModelEntry(entry, "obj"));
    const MODELS = (objModels.length
      ? objModels
      : triangleFiles.map((name) => createModelEntry(name, "json"))
    ).sort((a, b) => a.label.localeCompare(b.label));

    const DEFAULT_MODEL = MODELS[0] || null;

    // ── Category definitions ─────────────────────────────────────────────────

    const CATEGORY_DEFINITIONS = [
      { key: "characters", label: "Characters" },
      { key: "architecture", label: "Architecture" },
      { key: "vehicles", label: "Vehicles" },
      { key: "objects", label: "Objects" },
      { key: "environment", label: "Environment" },
    ];

    const CATEGORY_ORDER = CATEGORY_DEFINITIONS.map((c) => c.key);
    const CATEGORY_LABELS = CATEGORY_DEFINITIONS.reduce((acc, c) => {
      acc[c.key] = c.label;
      return acc;
    }, {});

    const JSON_MODEL_CATEGORY = {
      apple: "objects",
      blank: "objects",
      halfapple: "objects",
      mug: "objects",
      chair: "objects",
      cube: "objects",
      cylinder: "objects",
      pyramid: "objects",
      torus: "objects",
      chef: "characters",
      mailman: "characters",
      cat: "characters",
      dog: "characters",
      snowman: "characters",
    };

    const getModelCategoryKey = (model) => {
      if (!model) return "objects";
      if (model.type === "obj") return OBJ_MODEL_CONFIG[model.name]?.category || "objects";
      return JSON_MODEL_CATEGORY[model.name] || "objects";
    };

    // ── Camera defaults ──────────────────────────────────────────────────────

    const DEFAULT_CAMERA = { zoom: 0.2, rotX: 65, rotY: 45 };
    const MODEL_CAMERAS = {
      ...Object.fromEntries(
        Object.entries(OBJ_MODEL_CONFIG).map(([name, config]) => [name, config.camera || {}])
      ),
      halfapple: { zoom: 1.35 },
      apple: { zoom: 1.25 },
      cat: { zoom: 1, rotY: 220 },
      dog: { zoom: 1.3, rotY: 300 },
      chair: { zoom: 0.8, rotY: 300 },
      mug: { zoom: 1.1, rotY: 75 },
      chef: { zoom: 0.8, rotY: 300 },
      mailman: { zoom: 1, rotY: 300 },
      snowman: { zoom: 0.6, rotY: 300 },
    };

    const CAMERA_ZOOM_MIN = 0.1;
    const CAMERA_ZOOM_MAX = 2;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    // Per-model scene overrides — currently just a hint about whether the
    // floor should default off (e.g. floating models like `dual`, `pyramid`).
    const MODEL_SCENE_OVERRIDES = {
      dual: { showFloor: false },
      pyramid: { showFloor: false },
    };

    // ── State ────────────────────────────────────────────────────────────────

    let models = MODELS;
    let modelQuery = "";
    let activeModelId = DEFAULT_MODEL?.id || null;
    let loadedModelId = null;
    let isLoading = false;
    let openCategories = {};
    let loadAbortController = null;
    let requestToken = 0;

    // polycss scene handle
    let polyScene = null;
    let polyControls = null;
    let currentMesh = null;
    // Animation state lives on createPolyControls now — this page only tracks
    // whether the toolbar toggle is on (so re-mounts can restore the choice).
    let isAnimating = false;

    // Current camera/scene settings
    let currentZoom = DEFAULT_CAMERA.zoom;
    let currentRotX = DEFAULT_CAMERA.rotX;
    let currentRotY = DEFAULT_CAMERA.rotY;
    // Floor toggle — polycss has no floor primitive, so we synthesize a
    // single shaded polygon at z = bbox.min.z sized to the mesh footprint.
    // Mirrors the DebugScene approach in website/src/debug/DebugScene.tsx.
    let showFloor = false;
    // Cache the most-recent ParseResult so we can re-mount when the floor
    // toggle flips without re-fetching/re-parsing the model.
    let currentParseResult = null;

    // ── Computed helpers ─────────────────────────────────────────────────────

    const getFilteredModels = () => {
      const query = modelQuery.trim().toLowerCase();
      if (!query) return models;
      return models.filter((m) =>
        (m.label || "").toLowerCase().includes(query)
      );
    };

    const getModelCategories = (filteredModels) => {
      if (!filteredModels.length) return [];
      const categoriesByKey = new Map();

      for (const model of filteredModels) {
        const categoryKey = getModelCategoryKey(model);
        if (!categoryKey || !CATEGORY_LABELS[categoryKey]) continue;
        const categoryLabel = CATEGORY_LABELS[categoryKey];
        let category = categoriesByKey.get(categoryKey);
        if (!category) {
          category = { id: categoryKey, label: categoryLabel, models: [] };
          categoriesByKey.set(categoryKey, category);
        }
        category.models.push(model);
      }

      const categories = Array.from(categoriesByKey.values()).map((cat) => ({
        id: cat.id,
        label: cat.label,
        count: cat.models.length,
        models: cat.models.slice().sort((a, b) =>
          (a.label || "").localeCompare(b.label || "")
        ),
      }));

      categories.sort((a, b) => {
        const aI = CATEGORY_ORDER.indexOf(a.id);
        const bI = CATEGORY_ORDER.indexOf(b.id);
        const aR = aI === -1 ? Number.POSITIVE_INFINITY : aI;
        const bR = bI === -1 ? Number.POSITIVE_INFINITY : bI;
        if (aR !== bR) return aR - bR;
        return (a.label || "").localeCompare(b.label || "");
      });

      return categories;
    };

    const getActiveModel = () => models.find((m) => m.id === activeModelId) || null;

    const isCategoryOpen = (categoryId) => {
      if (modelQuery.trim()) return true;
      const value = openCategories[categoryId];
      if (value !== undefined) return value === true;
      return false;
    };

    // ── UI helpers ───────────────────────────────────────────────────────────

    const treeEl = document.getElementById("model-tree");
    const emptyEl = document.getElementById("model-empty");
    const zoomSlider = document.getElementById("zoom-slider");
    const zoomValueEl = document.getElementById("zoom-value");
    const loadingEl = document.getElementById("viewer-loading");
    const errorEl = document.getElementById("viewer-error");
    const animateToggle = document.getElementById("animate-toggle");
    const floorToggle = document.getElementById("floor-toggle");

    const setLoading = (val) => {
      isLoading = val;
      loadingEl.style.display = val ? "grid" : "none";
      if (val) errorEl.style.display = "none";
    };

    const setError = (msg) => {
      if (msg) {
        errorEl.textContent = msg;
        errorEl.style.display = "grid";
        loadingEl.style.display = "none";
      } else {
        errorEl.style.display = "none";
      }
    };

    const renderTree = () => {
      const filtered = getFilteredModels();
      const categories = getModelCategories(filtered);

      if (!categories.length) {
        treeEl.style.display = "none";
        emptyEl.style.display = "";
        return;
      }

      treeEl.style.display = "";
      emptyEl.style.display = "none";

      const html = categories.map((cat) => {
        const open = isCategoryOpen(cat.id);
        const modelBtns = cat.models.map((m) => {
          const isActive = m.id === activeModelId;
          return `<button type="button" class="sidebar-item${isActive ? " active" : ""}" data-model-id="${encodeURIComponent(m.id)}">${m.label}</button>`;
        }).join("");
        return `
          <div class="tree-category" data-cat-id="${cat.id}">
            <button type="button" class="tree-heading" aria-expanded="${open}" aria-controls="cat-${cat.id}" data-toggle-cat="${cat.id}">
              <span class="tree-label">
                <span class="tree-caret${open ? " open" : ""}">&#9658;</span>
                ${cat.label}
              </span>
              <span class="tree-count">${cat.count}</span>
            </button>
            <div class="model-button-list dark-scrollbar" id="cat-${cat.id}" ${open ? "" : 'style="display:none"'}>
              ${modelBtns}
            </div>
          </div>`;
      }).join("");

      treeEl.innerHTML = html;
    };

    const updateZoomUI = () => {
      zoomSlider.value = String(currentZoom);
      zoomValueEl.textContent = currentZoom.toFixed(2);
    };

    // ── polycss scene ────────────────────────────────────────────────────────

    const ensureScene = async () => {
      if (polyScene) return polyScene;
      const { createPolyScene, createPolyControls } = await import("polycss");
      const rootEl = document.getElementById("viewer-root");
      polyScene = createPolyScene(rootEl, {
        rotX: currentRotX,
        rotY: currentRotY,
        zoom: currentZoom,
        autoCenter: true,
        perspective: false,
      });
      // Drag + wheel on by default (the gallery viewer should always be
      // interactive); animate flips on/off via the toolbar toggle below.
      polyControls = createPolyControls(polyScene, {
        drag: true,
        wheel: true,
        animate: false,
      });
      return polyScene;
    };

    // Build a single shaded polygon at the mesh's lowest Z, padded 20% past
    // the mesh footprint so it visibly extends past the shape's edges.
    // Returns null if the mesh is empty / lacks finite bounds.
    const buildFloorPolygon = (polygons) => {
      if (!Array.isArray(polygons) || polygons.length === 0) return null;
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      let minZ = Infinity;
      for (const p of polygons) {
        const verts = p?.vertices;
        if (!Array.isArray(verts)) continue;
        for (const v of verts) {
          if (!Array.isArray(v) || v.length < 3) continue;
          if (v[0] < minX) minX = v[0]; if (v[0] > maxX) maxX = v[0];
          if (v[1] < minY) minY = v[1]; if (v[1] > maxY) maxY = v[1];
          if (v[2] < minZ) minZ = v[2];
        }
      }
      if (!Number.isFinite(minX) || !Number.isFinite(minZ)) return null;
      const padX = (maxX - minX) * 0.2;
      const padY = (maxY - minY) * 0.2;
      const x0 = minX - padX, x1 = maxX + padX;
      const y0 = minY - padY, y1 = maxY + padY;
      return {
        vertices: [
          [x0, y0, minZ],
          [x1, y0, minZ],
          [x1, y1, minZ],
          [x0, y1, minZ],
        ],
        color: "#3a3a3a",
      };
    };

    // Mount the cached parseResult (optionally augmented with a floor poly)
    // onto the scene. Reused by loadModel() and the floor toggle so we don't
    // refetch/reparse on UI changes.
    const remountCurrentMesh = async () => {
      if (!currentParseResult) return;
      const scene = await ensureScene();
      if (currentMesh) {
        currentMesh.remove();
        currentMesh = null;
      }
      let parseResult = currentParseResult;
      if (showFloor) {
        const floor = buildFloorPolygon(currentParseResult.polygons);
        if (floor) {
          parseResult = {
            polygons: [...currentParseResult.polygons, floor],
            objectUrls: currentParseResult.objectUrls || [],
            warnings: currentParseResult.warnings || [],
            // No-op dispose: real cleanup belongs to currentParseResult,
            // which we keep around independently.
            dispose: () => {},
          };
        }
      }
      currentMesh = scene.add(parseResult);
      updateStats(parseResult.polygons.length, currentMesh.polygons.length);
    };

    const updateStats = (inputCount, renderedCount) => {
      const statsEl = document.getElementById("viewer-stats");
      if (!statsEl) return;
      statsEl.classList.add("active");
      if (renderedCount !== inputCount) {
        statsEl.innerHTML =
          `<span class="viewer-stats__num">${renderedCount.toLocaleString()}</span> polygons` +
          `<span class="viewer-stats__delta">−${(inputCount - renderedCount).toLocaleString()}</span>`;
      } else {
        statsEl.innerHTML =
          `<span class="viewer-stats__num">${renderedCount.toLocaleString()}</span> polygons`;
      }
    };

    // ── URL query param sync ─────────────────────────────────────────────────

    const getRouteModelId = () => {
      const params = new URLSearchParams(window.location.search);
      return params.get("model") || "";
    };

    const resolveModelId = (routeValue) => {
      const value = typeof routeValue === "string" ? routeValue : String(routeValue || "");
      if (!value) return "";

      if (/^\d+$/.test(value)) {
        const numeric = Number(value);
        if (Number.isFinite(numeric)) {
          const byUrlId = models.find((m) => m.urlId === numeric);
          if (byUrlId) return byUrlId.id;
        }
      }

      const byId = models.find((m) => m.id === value);
      if (byId) return byId.id;
      const byLegacyKey = models.find((m) => m.legacyUrlKey === value);
      if (byLegacyKey) return byLegacyKey.id;
      return "";
    };

    const setRouteModelId = (modelId) => {
      let next = typeof modelId === "string" ? modelId : "";
      if (next) {
        const model = models.find((m) => m.id === next);
        next = model ? String(model.urlId) : next;
      }
      const current = getRouteModelId();
      if (next && next === current) return;
      if (!next && !current) return;

      const params = new URLSearchParams(window.location.search);
      if (next) params.set("model", next);
      else params.delete("model");

      const newSearch = params.toString();
      const newUrl =
        window.location.pathname + (newSearch ? "?" + newSearch : "") + window.location.hash;
      history.replaceState(null, "", newUrl);
    };

    // ── Animation loop ───────────────────────────────────────────────────────
    // Delegated to createPolyControls — it owns the dt-clamped rAF tick. The
    // start/stop helpers here just flip its `animate` option on/off.

    function startAnim() {
      if (isAnimating || !polyControls) return;
      isAnimating = true;
      polyControls.update({
        animate: { speed: 0.3, axis: "y", pauseOnInteraction: true },
      });
    }

    function stopAnim() {
      if (!polyControls) { isAnimating = false; return; }
      isAnimating = false;
      polyControls.update({ animate: false });
    }

    // ── Model loading ────────────────────────────────────────────────────────

    const applyModelDefaults = (model) => {
      const overrides = MODEL_CAMERAS[model.name] || {};
      const base = { ...DEFAULT_CAMERA, ...overrides };

      const mobileZoomOut = window.matchMedia("(max-width: 480px)").matches
        ? 0.5
        : window.matchMedia("(max-width: 960px)").matches
          ? 0.68
          : 1;

      currentZoom = clamp(base.zoom * mobileZoomOut, CAMERA_ZOOM_MIN, CAMERA_ZOOM_MAX);
      // Mobile pitch nudge — the original voxcss page tilted the camera a
      // few degrees on small viewports so the on-screen control strip didn't
      // hide the model. polycss has no separate `tilt` axis, so we apply
      // the nudge directly to rotX (pitch).
      const mobileTilt = window.matchMedia("(max-width: 480px)").matches
        ? -10
        : window.matchMedia("(max-width: 960px)").matches
          ? -6
          : 0;
      currentRotX = base.rotX + mobileTilt;
      currentRotY = base.rotY;

      // Per-model floor default: floating models (e.g. dual, pyramid) look
      // wrong with a floor, so force it off when the user hasn't opted in.
      const sceneOverrides =
        MODEL_SCENE_OVERRIDES[(model.name || "").toLowerCase()] || {};
      if (typeof sceneOverrides.showFloor === "boolean") {
        showFloor = sceneOverrides.showFloor;
        if (floorToggle) floorToggle.checked = showFloor;
      }

      updateZoomUI();
    };

    const loadModel = async (modelOrId) => {
      const model =
        typeof modelOrId === "string"
          ? models.find((m) => m.id === modelOrId)
          : modelOrId;
      if (!model) return;

      if (loadAbortController) {
        loadAbortController.abort();
      }
      const abortController =
        typeof AbortController !== "undefined" ? new AbortController() : null;
      loadAbortController = abortController;

      const token = ++requestToken;
      setError(null);
      setLoading(true);

      try {
        // Two loaders, one shape:
        //   "obj"  → loadMesh() dispatches to parseObj, with MTL when present.
        //   "json" → fetch a pre-baked Polygon[] file (face-culled offline).
        // Both yield a ParseResult that scene.add() consumes the same way.
        let parseResult;
        if (model.type === "obj") {
          const polycss = await import("polycss");
          const config = OBJ_MODEL_CONFIG[model.name] || {};
          const loadOptions = {};
          if (model.hasMtl) loadOptions.mtlUrl = `/gallery/obj/${model.name}.mtl`;
          if (config.options) loadOptions.objOptions = config.options;
          parseResult = await polycss.loadMesh(`/gallery/obj/${model.name}.obj`, loadOptions);
        } else {
          const res = await fetch(
            `/gallery/${model.name}.json`,
            abortController ? { signal: abortController.signal } : undefined
          );
          if (!res.ok) throw new Error(`Fetch failed: ${res.status}`);
          const polygons = await res.json();
          parseResult = { polygons, objectUrls: [], warnings: [], dispose: () => {} };
        }

        if (abortController?.signal?.aborted) return;
        if (token !== requestToken) return;

        // Dispose previous parseResult before swapping (frees blob URLs).
        if (currentParseResult && currentParseResult !== parseResult) {
          try { currentParseResult.dispose(); } catch (_) {}
        }
        currentParseResult = parseResult;

        applyModelDefaults(model);
        const scene = await ensureScene();
        scene.setOptions({
          rotX: currentRotX,
          rotY: currentRotY,
          zoom: currentZoom,
        });

        await remountCurrentMesh();
        loadedModelId = model.id;
        setLoading(false);
      } catch (err) {
        if (abortController?.signal?.aborted || err?.name === "AbortError") return;
        if (token !== requestToken) return;
        setLoading(false);
        setError(
          typeof err?.message === "string" && err.message
            ? err.message
            : "Could not load model"
        );
        if (loadedModelId) {
          activeModelId = loadedModelId;
          renderTree();
          if (getRouteModelId()) {
            setRouteModelId(loadedModelId);
          }
        }
      } finally {
        if (loadAbortController === abortController) {
          loadAbortController = null;
        }
      }
    };

    const setActiveModel = (modelId, options = {}) => {
      const updateRoute = options.updateRoute === true;
      if (!modelId) return;
      const model = models.find((m) => m.id === modelId);
      if (!model) return;

      activeModelId = modelId;
      renderTree();
      if (updateRoute) setRouteModelId(modelId);
      if (modelId !== loadedModelId) {
        loadModel(model);
      }
    };

    const selectModel = (modelId) => {
      setActiveModel(modelId, { updateRoute: true });
    };

    const randomizeModel = () => {
      const filtered = getFilteredModels();
      const pool = filtered.length ? filtered : models;
      if (!pool.length) return;

      let next = pool[Math.floor(Math.random() * pool.length)] || pool[0];
      if (pool.length > 1 && activeModelId) {
        let guard = 0;
        while (next?.id === activeModelId && guard < 8) {
          next = pool[Math.floor(Math.random() * pool.length)] || pool[0];
          guard += 1;
        }
      }

      if (!next?.id) return;
      setActiveModel(next.id, { updateRoute: true });
    };

    // ── Event listeners ──────────────────────────────────────────────────────

    document.getElementById("btn-random-sidebar").addEventListener("click", randomizeModel);
    document.getElementById("btn-random-mobile").addEventListener("click", randomizeModel);

    const searchInput = document.getElementById("model-search");
    searchInput.addEventListener("input", () => {
      modelQuery = searchInput.value.trim();
      renderTree();
    });

    zoomSlider.addEventListener("input", () => {
      currentZoom = Number(zoomSlider.value);
      zoomValueEl.textContent = currentZoom.toFixed(2);
      if (polyScene) polyScene.setOptions({ zoom: currentZoom });
    });

    animateToggle.addEventListener("change", () => {
      if (animateToggle.checked) {
        startAnim();
      } else {
        stopAnim();
      }
    });

    floorToggle.addEventListener("change", () => {
      showFloor = floorToggle.checked;
      // Re-mount the cached parse result with/without the synthesized floor.
      // No re-fetch: cheap enough to keep instant.
      remountCurrentMesh();
    });

    // Delegate model selection and category toggle from tree
    treeEl.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-model-id]");
      if (btn) {
        selectModel(decodeURIComponent(btn.dataset.modelId));
        return;
      }
      const catToggle = e.target.closest("button[data-toggle-cat]");
      if (catToggle) {
        const catId = catToggle.dataset.toggleCat;
        const next = !isCategoryOpen(catId);
        openCategories[catId] = next;
        renderTree();
      }
    });

    // GitHub star count
    async function fetchStars() {
      try {
        const res = await fetch("https://api.github.com/repos/LayoutitStudio/polycss");
        if (!res.ok) return;
        const json = await res.json();
        if (typeof json?.stargazers_count === "number") {
          const text = `★ ${json.stargazers_count}`;
          const el = document.getElementById("star-count-nav");
          if (el) el.textContent = text;
        }
      } catch (_) {}
    }
    fetchStars();

    // ── Init ─────────────────────────────────────────────────────────────────

    const init = async () => {
      const routeModelId = getRouteModelId();
      if (routeModelId) {
        const resolvedId = resolveModelId(routeModelId);
        if (resolvedId) {
          activeModelId = resolvedId;
        } else {
          setRouteModelId(null);
        }
      } else if (models.length) {
        // No `?model=` on URL — pick a random architecture model so the page
        // opens with something visually interesting.
        const scenePool = models.filter((m) => getModelCategoryKey(m) === "architecture");
        const pool = scenePool.length ? scenePool : models;
        const pick = pool[Math.floor(Math.random() * pool.length)] || pool[0];
        if (pick?.id) activeModelId = pick.id;
      }

      // Sync UI to (possibly model-derived) state.
      if (floorToggle) floorToggle.checked = showFloor;
      renderTree();
      updateZoomUI();

      const activeModel = getActiveModel();
      if (activeModelId && activeModel) {
        await loadModel(activeModel);
      }
    };

    init();

    // Handle popstate for back/forward navigation
    window.addEventListener("popstate", () => {
      const routeValue = getRouteModelId();
      if (!routeValue) return;
      const resolvedId = resolveModelId(routeValue);
      if (!resolvedId) {
        setRouteModelId(null);
        return;
      }
      if (resolvedId === activeModelId) return;
      setActiveModel(resolvedId, { updateRoute: false });
    });
  </script>

