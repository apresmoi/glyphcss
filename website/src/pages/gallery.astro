---
import fs from 'fs';
import path from 'path';

const SITE_URL = "https://voxcss.com";
const OG_IMAGE = `${SITE_URL}/voxcss-intro.png`;
const SITE_NAME = "VoxCSS";

const galleryDir = path.resolve(process.cwd(), 'public/gallery');

let jsonFiles: string[] = [];
let voxManifest: string[] = [];

try {
  jsonFiles = fs.readdirSync(galleryDir)
    .filter(f => f.endsWith('.json') && f !== 'vox-manifest.json');
  const manifestPath = path.join(galleryDir, 'vox-manifest.json');
  if (fs.existsSync(manifestPath)) {
    voxManifest = JSON.parse(fs.readFileSync(manifestPath, 'utf-8'));
  }
} catch {
  // Gallery assets not present (clean checkout) — page still renders, models load at runtime
}

const title = "VoxCSS Gallery — CSS voxel models";
const description =
  "Browse downloadable VoxCSS voxel scenes used in the docs: apples, characters, terrains, and more rendered with pure CSS grids.";
const url = `${SITE_URL}/gallery`;

const ldJson = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url,
  image: OG_IMAGE,
  about: {
    "@type": "SoftwareApplication",
    name: SITE_NAME,
    url: SITE_URL,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
    url: SITE_URL,
  },
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <link rel="canonical" href={url} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  <style is:global>
    html { background: #0b0d10; color: #e2e8f0; }
    body { margin: 0; }
  </style>
</head>
<body>
  <div class="docs-shell">
    <aside class="docs-nav">
      <nav>
        <div class="docs-nav__brand">
          <a href="/" class="docs-nav__logo" aria-label="voxCSS home">
            <img class="docs-nav__logo-img" src="/voxisologo.png" alt="voxCSS" />
          </a>
        </div>
        <div class="nav-group">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/quickstart">Usage</a></li>
            <li><a href="/api/headless"><span class="nav-label"><span class="nav-label__short">API</span><span class="nav-label__long"> Reference</span></span></a></li>
            <li><a href="/gallery" class="active">Gallery</a></li>
          </ul>
        </div>
        <div class="docs-nav__spacer">
          <a
            class="github-social github-social--compact"
            href="https://github.com/LayoutitStudio/voxcss"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View voxCSS on GitHub"
          >
            <span class="github-social__main">
              <svg class="github-social__icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
              </svg>
              <span>GitHub</span>
            </span>
            <span class="github-social__count" id="star-count-nav">&#9733; &hellip;</span>
          </a>
        </div>
      </nav>
    </aside>

    <main class="docs-content docs-content--gallery">
      <div class="gallery-page" id="gallery-page">
        <section class="viewer-panel card">
          <div class="viewer-canvas" id="viewer-root">
            <div class="headless-camera" id="gallery-camera">
              <div class="headless-scene" id="gallery-scene"></div>
            </div>
            <div class="viewer-state viewer-loading" id="viewer-loading" style="display:none">Loading&hellip;</div>
            <div class="viewer-state viewer-error" id="viewer-error" style="display:none"></div>
          </div>
        </section>

        <aside class="models-sidebar" aria-label="Models">
          <div class="models-sidebar__body dark-scrollbar">
            <div class="models-sidebar__header">
              <input
                class="model-search models-sidebar__search"
                type="search"
                placeholder="Search models"
                id="model-search"
                autocomplete="off"
              />
              <button type="button" class="control-btn control-btn--primary" id="btn-random-sidebar">
                Load Random
              </button>
            </div>

            <div class="model-tree dark-scrollbar" id="model-tree"></div>
            <div class="model-empty" id="model-empty" style="display:none">No matching models</div>

            <p class="model-credit">
              Sources:
              <a href="https://github.com/mikelovesrobots/mmmm" target="_blank" rel="noopener noreferrer">mmmm</a>
              &middot;
              <a href="https://github.com/ephtracy/voxel-model/" target="_blank" rel="noopener noreferrer">voxel-model</a>
              &middot;
              <a href="https://github.com/kluchek/vox-models" target="_blank" rel="noopener noreferrer">vox-models</a>
            </p>
          </div>
        </aside>

        <div class="controls-strip" aria-label="Showcase controls">
          <div class="controls-strip__row dark-scrollbar">
            <form class="controls-stack" id="controls-form">
              <button type="button" class="control-btn control-btn--primary control-btn--mobile-only" id="btn-random-mobile">
                Load Random
              </button>
              <label>
                <span class="range-heading">
                  <span>zoom</span>
                  <span class="range-value" id="zoom-value">1.20</span>
                </span>
                <input type="range" min="0.1" max="2" step="0.01" id="zoom-slider" value="1.2" />
              </label>

              <label class="switch">
                <input type="checkbox" id="animate-toggle" />
                <span>animate</span>
              </label>

              <label class="switch">
                <input type="checkbox" id="floor-toggle" checked />
                <span>show floor</span>
              </label>

              <label class="control-label" style="display:flex;flex-direction:column;gap:4px;">
                <span class="range-heading"><span>merge mode</span></span>
                <select id="merge-select" style="padding:6px 8px;border-radius:4px;background:rgba(255,255,255,0.05);color:inherit;border:1px solid rgba(255,255,255,0.15);font:inherit;">
                  <option value="false">off (per voxel)</option>
                  <option value="2d">2d (per Z slice)</option>
                  <option value="3d" selected>3d (slice render)</option>
                </select>
              </label>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script type="application/json" id="gallery-json-files" set:html={JSON.stringify(jsonFiles)} />
  <script type="application/json" id="gallery-vox-manifest" set:html={JSON.stringify(voxManifest)} />

  <script>
    // ── Utilities ────────────────────────────────────────────────────────────

    const hashStringToUint32 = (value) => {
      const str = typeof value === "string" ? value : "";
      let hash = 2166136261;
      for (let i = 0; i < str.length; i += 1) {
        hash ^= str.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }
      return hash >>> 0;
    };

    const toToken = (value) => (typeof value === "string" ? value : "").trim();

    const humanizeToken = (token) => {
      const cleaned = toToken(token).replace(/[_-]+/g, " ");
      if (!cleaned) return "";
      return cleaned.replace(/\b[a-z]/gi, (char) => char.toUpperCase());
    };

    const splitModelKey = (cameraKey) => {
      const key = toToken(cameraKey);
      const parts = key.split("_");
      if (parts.length >= 2) {
        return {
          prefix: parts[0].toLowerCase(),
          rest: parts.slice(1).join("_"),
        };
      }
      return { prefix: "", rest: key };
    };

    const createModelEntry = (file, typeOverride) => {
      const normalized = file.replace(/^\.\//, "");
      const type = typeOverride || (/\.vox$/i.test(normalized) ? "vox" : "json");
      const name = normalized.replace(/\.(json|vox)$/i, "");
      const cameraKey = name.split("/").pop() || name;
      const baseLabel = cameraKey.replace(/[_-]/g, " ");
      const label =
        type === "vox"
          ? humanizeToken(splitModelKey(cameraKey).rest)
          : humanizeToken(baseLabel);
      const id = `${type}:${name}`;
      return {
        id,
        type,
        name,
        path: normalized,
        cameraKey,
        label,
        urlId: hashStringToUint32(id),
        legacyUrlKey: `${type}:${cameraKey}`,
      };
    };

    // ── Model data (injected at build time) ──────────────────────────────────

    const jsonFiles = JSON.parse(
      document.getElementById("gallery-json-files").textContent
    );
    const voxManifest = JSON.parse(
      document.getElementById("gallery-vox-manifest").textContent
    );

    const JSON_MODELS = jsonFiles.map((f) => createModelEntry(f, "json"));
    const VOX_MODELS = Array.isArray(voxManifest)
      ? voxManifest.map((f) => createModelEntry(f, "vox"))
      : [];

    const MODELS = [...JSON_MODELS, ...VOX_MODELS].sort((a, b) =>
      a.label.localeCompare(b.label)
    );

    const DEFAULT_MODEL =
      MODELS.find((model) => model.type === "json") || MODELS[0] || null;

    // ── Category definitions ─────────────────────────────────────────────────

    const CATEGORY_DEFINITIONS = [
      { key: "scenes", label: "Scenes" },
      { key: "characters", label: "Characters" },
      { key: "objects", label: "Objects" },
      { key: "vehicles", label: "Vehicles" },
      { key: "environment", label: "Environment" },
    ];

    const CATEGORY_ORDER = CATEGORY_DEFINITIONS.map((c) => c.key);
    const CATEGORY_LABELS = CATEGORY_DEFINITIONS.reduce((acc, c) => {
      acc[c.key] = c.label;
      return acc;
    }, {});

    const VOX_PREFIX_CATEGORY = {
      scene: "scenes",
      chr: "characters",
      obj: "objects",
      veh: "vehicles",
      alien: "characters",
      env: "environment",
      mob: "characters",
    };

    const VOX_MODEL_CATEGORY = {
      dual: "scenes",
      pyramid: "objects",
    };

    const JSON_MODEL_CATEGORY = {
      apple: "objects",
      blank: "objects",
      halfapple: "objects",
      mug: "objects",
      chair: "objects",
      cube: "objects",
      cylinder: "objects",
      pyramid: "objects",
      torus: "objects",
      chef: "characters",
      mailman: "characters",
      cat: "characters",
      dog: "characters",
      snowman: "characters",
    };

    const getModelCameraKey = (model) =>
      toToken(model?.cameraKey) || toToken(model?.name);

    const getModelCategoryKey = (model) => {
      if (model?.type === "json") {
        const key = splitModelKey(getModelCameraKey(model)).rest || "";
        return JSON_MODEL_CATEGORY[key] || "objects";
      }
      if (model?.type !== "vox") return "";
      const { prefix, rest } = splitModelKey(getModelCameraKey(model));
      return (
        VOX_PREFIX_CATEGORY[prefix] ||
        VOX_MODEL_CATEGORY[toToken(rest).toLowerCase()] ||
        ""
      );
    };

    // ── Camera / scene defaults ──────────────────────────────────────────────

    const DEFAULT_CAMERA = { zoom: 1.2, rotX: 65, rotY: 45 };
    const MODEL_CAMERAS = {
      halfapple: { zoom: 1.35 },
      apple: { zoom: 1.25 },
      cat: { zoom: 1, rotY: 220 },
      dog: { zoom: 1.3, rotY: 300 },
      chair: { zoom: 0.8, rotY: 300 },
      mug: { zoom: 1.1, rotY: 75 },
      chef: { zoom: 0.8, rotY: 300 },
      mailman: { zoom: 1, rotY: 300 },
      snowman: { zoom: 0.6, rotY: 300 },
      octahedron: { zoom: 1.1, rotY: 45 },
      tetrahedron: { zoom: 1.25, rotY: 30 },
    };

    const MODEL_SCENE_DIMENSIONS = {
      blank: { rows: 8, cols: 8, depth: 6 },
    };

    const MODEL_SCENE_OVERRIDES = {
      dual: { showFloor: false },
      pyramid: { showFloor: false },
    };

    const IOS_VOXEL_LIMIT = 30000;
    const CAMERA_ZOOM_MIN = 0.1;
    const CAMERA_ZOOM_MAX = 2;

    // ── iOS detection ────────────────────────────────────────────────────────

    const isProbablyIOS = () => {
      if (typeof navigator === "undefined") return false;
      const ua = navigator.userAgent || "";
      const platform = navigator.platform || "";
      return (
        /iPad|iPhone|iPod/.test(ua) ||
        (platform === "MacIntel" && (navigator.maxTouchPoints || 0) > 1)
      );
    };

    // ── VOX meta reader ──────────────────────────────────────────────────────

    const readMagicaVoxelMeta = (buffer) => {
      if (!(buffer instanceof ArrayBuffer)) return null;
      const view = new DataView(buffer);
      if (view.byteLength < 20) return null;

      const readChunkId = (offset) =>
        String.fromCharCode(
          view.getUint8(offset),
          view.getUint8(offset + 1),
          view.getUint8(offset + 2),
          view.getUint8(offset + 3)
        );

      if (readChunkId(0) !== "VOX ") return null;
      if (readChunkId(8) !== "MAIN") return null;

      const mainContentSize = view.getUint32(12, true);
      const mainChildrenSize = view.getUint32(16, true);
      let offset = 20 + mainContentSize;
      const end = Math.min(view.byteLength, offset + mainChildrenSize);

      let voxelCount = null;
      let dimensions = null;

      while (offset + 12 <= end) {
        const chunkId = readChunkId(offset);
        const chunkSize = view.getUint32(offset + 4, true);
        const childSize = view.getUint32(offset + 8, true);
        const chunkStart = offset + 12;

        if (chunkId === "SIZE" && chunkStart + 12 <= end && chunkSize >= 12) {
          dimensions = {
            x: view.getInt32(chunkStart, true),
            y: view.getInt32(chunkStart + 4, true),
            z: view.getInt32(chunkStart + 8, true),
          };
        }

        if (chunkId === "XYZI" && chunkStart + 4 <= end && chunkSize >= 4) {
          voxelCount = view.getInt32(chunkStart, true);
        }

        offset = chunkStart + chunkSize + childSize;
        if (chunkId === "XYZI") break;
      }

      return { voxelCount, dimensions };
    };

    const safeNumberString = (value) => {
      const num = typeof value === "number" ? value : Number(value);
      if (!Number.isFinite(num)) return "";
      try {
        return num.toLocaleString();
      } catch (_err) {
        return String(num);
      }
    };

    // ── Auto-zoom ────────────────────────────────────────────────────────────

    const toFiniteNumber = (value) => {
      const num = typeof value === "number" ? value : Number(value);
      return Number.isFinite(num) ? num : null;
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const getVoxelBounds = (voxels) => {
      if (!Array.isArray(voxels) || !voxels.length) return null;

      let minX = Number.POSITIVE_INFINITY;
      let minY = Number.POSITIVE_INFINITY;
      let minZ = Number.POSITIVE_INFINITY;
      let maxX = Number.NEGATIVE_INFINITY;
      let maxY = Number.NEGATIVE_INFINITY;
      let maxZ = Number.NEGATIVE_INFINITY;

      for (const voxel of voxels) {
        const x = toFiniteNumber(voxel?.x);
        const y = toFiniteNumber(voxel?.y);
        const z = toFiniteNumber(voxel?.z);
        if (x === null || y === null || z === null) continue;

        const x2 = toFiniteNumber(voxel?.x2) ?? x + 1;
        const y2 = toFiniteNumber(voxel?.y2) ?? y + 1;
        const z2 = toFiniteNumber(voxel?.z2) ?? z + 1;

        minX = Math.min(minX, x);
        minY = Math.min(minY, y);
        minZ = Math.min(minZ, z);

        maxX = Math.max(maxX, x2);
        maxY = Math.max(maxY, y2);
        maxZ = Math.max(maxZ, z2);
      }

      if (!Number.isFinite(minX) || !Number.isFinite(maxX)) return null;
      return {
        minX, minY, minZ, maxX, maxY, maxZ,
        width: Math.max(0, maxX - minX),
        height: Math.max(0, maxY - minY),
        depth: Math.max(0, maxZ - minZ),
      };
    };

    const getAutoZoom = (voxels) => {
      const bounds = getVoxelBounds(voxels);
      if (!bounds) return null;

      const footprint = Math.hypot(bounds.width, bounds.depth);
      const heightWeight = 0.9;
      const fitDim = Math.max(footprint, bounds.height * heightWeight);
      if (!Number.isFinite(fitDim) || fitDim <= 0) return null;

      const tRaw = (fitDim - 14) / 42;
      const t = clamp(tRaw, 0, 1);
      const smoothT = t * t * (3 - 2 * t);

      const targetDim = 14;
      const zoomOut = 0.84 + smoothT * 0.32;
      return clamp(
        (targetDim / fitDim) * zoomOut,
        CAMERA_ZOOM_MIN,
        Math.min(1.6, CAMERA_ZOOM_MAX)
      );
    };

    // ── State ────────────────────────────────────────────────────────────────

    let models = MODELS;
    let modelQuery = "";
    let activeModelId = DEFAULT_MODEL?.id || null;
    let loadedModelId = DEFAULT_MODEL?.id || null;
    let currentGrid = [];
    let isLoading = false;
    let errorMsg = MODELS.length ? null : "No gallery available";
    let requestToken = 0;
    let loadAbortController = null;
    let renderer = null;
    let rendererInitPromise = null;
    let voxcssLib = null;
    let openCategories = {};
    let scene = {
      showWalls: false,
      showFloor: true,
      projection: "cubic",
      mergeVoxels: "3d",
    };
    let camera = {
      zoom: DEFAULT_CAMERA.zoom,
      pan: 0,
      tilt: 0,
      rotX: DEFAULT_CAMERA.rotX,
      rotY: DEFAULT_CAMERA.rotY,
      interactive: true,
      invert: false,
      autoRotate: false,
      autoRotateAxis: "y",
      autoRotateSpeed: 0.3,
      autoRotatePauseOnInteraction: true,
    };

    // ── Computed helpers ─────────────────────────────────────────────────────

    const getFilteredModels = () => {
      const query = modelQuery.trim().toLowerCase();
      if (!query) return models;
      return models.filter((m) =>
        (m.label || "").toLowerCase().includes(query)
      );
    };

    const getModelCategories = (filteredModels) => {
      if (!filteredModels.length) return [];
      const categoriesByKey = new Map();

      for (const model of filteredModels) {
        const categoryKey = getModelCategoryKey(model);
        if (!categoryKey || !CATEGORY_LABELS[categoryKey]) continue;
        const categoryLabel = CATEGORY_LABELS[categoryKey];
        let category = categoriesByKey.get(categoryKey);
        if (!category) {
          category = { id: categoryKey, label: categoryLabel, models: [] };
          categoriesByKey.set(categoryKey, category);
        }
        category.models.push(model);
      }

      const categories = Array.from(categoriesByKey.values()).map((cat) => ({
        id: cat.id,
        label: cat.label,
        count: cat.models.length,
        models: cat.models.slice().sort((a, b) =>
          (a.label || "").localeCompare(b.label || "")
        ),
      }));

      categories.sort((a, b) => {
        const aI = CATEGORY_ORDER.indexOf(a.id);
        const bI = CATEGORY_ORDER.indexOf(b.id);
        const aR = aI === -1 ? Number.POSITIVE_INFINITY : aI;
        const bR = bI === -1 ? Number.POSITIVE_INFINITY : bI;
        if (aR !== bR) return aR - bR;
        return (a.label || "").localeCompare(b.label || "");
      });

      return categories;
    };

    const getActiveModel = () => models.find((m) => m.id === activeModelId) || null;
    const getLoadedModel = () => models.find((m) => m.id === loadedModelId) || null;

    const isCategoryOpen = (categoryId) => {
      if (modelQuery.trim()) return true;
      const value = openCategories[categoryId];
      if (value !== undefined) return value === true;
      return false;
    };

    const getCameraBase = () => {
      const loadedModel = getLoadedModel();
      const cameraKey = loadedModel?.cameraKey || loadedModel?.name || "";
      const overrides = MODEL_CAMERAS[cameraKey] || {};
      return { ...DEFAULT_CAMERA, ...overrides };
    };

    const getCameraSettings = () => {
      const cameraBase = getCameraBase();
      const zoom = typeof camera.zoom === "number" ? camera.zoom : cameraBase.zoom;
      const rotX = typeof camera.rotX === "number" ? camera.rotX : cameraBase.rotX;
      const rotY = typeof camera.rotY === "number" ? camera.rotY : cameraBase.rotY;
      const rotYAdjusted = (rotY + 180) % 360;
      const pan = typeof camera.pan === "number" ? camera.pan : 0;
      const tilt = typeof camera.tilt === "number" ? camera.tilt : 0;
      const interactive = camera.interactive !== false;
      const invert = camera.invert === true;
      const perspective = false;
      const autoRotate = camera.autoRotate === true;
      const autoRotateSpeed =
        typeof camera.autoRotateSpeed === "number" ? camera.autoRotateSpeed : 0.3;
      const animate =
        autoRotate && Number.isFinite(autoRotateSpeed) && autoRotateSpeed !== 0
          ? {
              axis: camera.autoRotateAxis === "x" ? "x" : "y",
              speed: autoRotateSpeed,
              pauseOnInteraction: camera.autoRotatePauseOnInteraction !== false,
            }
          : false;

      return { zoom, rotX, rotY: rotYAdjusted, pan, tilt, interactive, invert, perspective, animate };
    };

    const getSceneSettings = () => {
      const loadedModel = getLoadedModel();
      const cameraKey = loadedModel?.cameraKey || loadedModel?.name || "";
      const dimensions = MODEL_SCENE_DIMENSIONS[cameraKey] || {};
      return {
        voxels: currentGrid,
        ...dimensions,
        showWalls: scene.showWalls,
        showFloor: scene.showFloor,
        projection: scene.projection,
        mergeVoxels: scene.mergeVoxels,
      };
    };

    // ── UI rendering ─────────────────────────────────────────────────────────

    const treeEl = document.getElementById("model-tree");
    const emptyEl = document.getElementById("model-empty");
    const zoomSlider = document.getElementById("zoom-slider");
    const zoomValueEl = document.getElementById("zoom-value");
    const loadingEl = document.getElementById("viewer-loading");
    const errorEl = document.getElementById("viewer-error");
    const animateToggle = document.getElementById("animate-toggle");
    const floorToggle = document.getElementById("floor-toggle");
    const mergeSelect = document.getElementById("merge-select");

    const setLoading = (val) => {
      isLoading = val;
      loadingEl.style.display = val ? "grid" : "none";
      if (val) errorEl.style.display = "none";
    };

    const setError = (msg) => {
      errorMsg = msg;
      if (msg) {
        errorEl.textContent = msg;
        errorEl.style.display = "grid";
        loadingEl.style.display = "none";
      } else {
        errorEl.style.display = "none";
      }
    };

    const renderTree = () => {
      const filtered = getFilteredModels();
      const categories = getModelCategories(filtered);

      if (!categories.length) {
        treeEl.style.display = "none";
        emptyEl.style.display = "";
        return;
      }

      treeEl.style.display = "";
      emptyEl.style.display = "none";

      // Preserve existing open state, re-render buttons
      const html = categories.map((cat) => {
        const open = isCategoryOpen(cat.id);
        const modelBtns = cat.models.map((m) => {
          const isActive = m.id === activeModelId;
          return `<button type="button" class="sidebar-item${isActive ? " active" : ""}" data-model-id="${encodeURIComponent(m.id)}">${m.label}</button>`;
        }).join("");
        return `
          <div class="tree-category" data-cat-id="${cat.id}">
            <button type="button" class="tree-heading" aria-expanded="${open}" aria-controls="cat-${cat.id}" data-toggle-cat="${cat.id}">
              <span class="tree-label">
                <span class="tree-caret${open ? " open" : ""}">▸</span>
                ${cat.label}
              </span>
              <span class="tree-count">${cat.count}</span>
            </button>
            <div class="model-button-list dark-scrollbar" id="cat-${cat.id}" ${open ? "" : 'style="display:none"'}>
              ${modelBtns}
            </div>
          </div>`;
      }).join("");

      treeEl.innerHTML = html;
    };

    const updateZoomUI = () => {
      zoomSlider.value = String(camera.zoom);
      zoomValueEl.textContent = camera.zoom.toFixed(2);
    };

    // ── voxcss loading ───────────────────────────────────────────────────────

    const ensureVoxcss = async () => {
      if (voxcssLib) return voxcssLib;
      voxcssLib = await import("@layoutit/voxcss");
      return voxcssLib;
    };

    // ── Renderer ─────────────────────────────────────────────────────────────

    const destroyRenderer = () => {
      if (renderer) {
        renderer.handle?.destroy?.();
        renderer.camera?.destroy?.();
        renderer = null;
      }
    };

    const initRenderer = async () => {
      if (rendererInitPromise) return rendererInitPromise;

      rendererInitPromise = (async () => {
        const lib = await ensureVoxcss();
        const cameraEl = document.getElementById("gallery-camera");
        const sceneEl = document.getElementById("gallery-scene");
        const rootEl = document.getElementById("viewer-root");
        if (!lib || !rootEl || !cameraEl || !sceneEl) return;
        destroyRenderer();

        const cam = lib.createCamera({
          element: cameraEl,
          ...getCameraSettings(),
        });
        const sc = lib.createScene({
          element: sceneEl,
          ...getSceneSettings(),
        });
        const handle = lib.renderScene({ element: rootEl, camera: cam, scene: sc });
        renderer = { handle, camera: cam };
      })();

      try {
        await rendererInitPromise;
      } finally {
        rendererInitPromise = null;
      }
    };

    const updateCamera = async () => {
      if (!renderer?.camera?.update) {
        await initRenderer();
      }
      renderer?.camera?.update?.(getCameraSettings());
    };

    const updateScene = async () => {
      if (!renderer?.handle?.setScene) {
        await initRenderer();
      }
      renderer?.handle?.setScene?.(getSceneSettings());
    };

    // ── URL query param sync ─────────────────────────────────────────────────

    const getRouteModelId = () => {
      const params = new URLSearchParams(window.location.search);
      return params.get("model") || "";
    };

    const resolveModelId = (routeValue) => {
      const value = typeof routeValue === "string" ? routeValue : String(routeValue || "");
      if (!value) return "";

      if (/^\d+$/.test(value)) {
        const numeric = Number(value);
        if (Number.isFinite(numeric)) {
          const byUrlId = models.find((m) => m.urlId === numeric);
          if (byUrlId) return byUrlId.id;
        }
      }

      const byId = models.find((m) => m.id === value);
      if (byId) return byId.id;
      const byLegacyKey = models.find((m) => m.legacyUrlKey === value);
      if (byLegacyKey) return byLegacyKey.id;
      return "";
    };

    const setRouteModelId = (modelId) => {
      let next = typeof modelId === "string" ? modelId : "";
      if (next) {
        const model = models.find((m) => m.id === next);
        next = model ? String(model.urlId) : next;
      }
      const current = getRouteModelId();
      if (next && next === current) return;
      if (!next && !current) return;

      const params = new URLSearchParams(window.location.search);
      if (next) params.set("model", next);
      else params.delete("model");

      const newSearch = params.toString();
      const newUrl =
        window.location.pathname + (newSearch ? "?" + newSearch : "") + window.location.hash;
      history.replaceState(null, "", newUrl);
    };

    // ── Model loading ────────────────────────────────────────────────────────

    const applyModelDefaults = () => {
      const loadedModel = getLoadedModel();
      const cameraKey = loadedModel?.cameraKey || loadedModel?.name || "";
      const overrides = MODEL_CAMERAS[cameraKey] || {};
      const sceneOverrides =
        MODEL_SCENE_OVERRIDES[toToken(cameraKey).toLowerCase()] || {};
      const autoZoom = getAutoZoom(currentGrid);

      if (typeof autoZoom === "number") {
        const navHeight = 72;
        const headerCompensation =
          window.innerHeight > navHeight
            ? clamp(window.innerHeight / (window.innerHeight - navHeight), 1, 1.12)
            : 1;
        const mobileZoomOut = window.matchMedia("(max-width: 480px)").matches
          ? 0.5
          : window.matchMedia("(max-width: 960px)").matches
            ? 0.68
            : 1;
        const multiplier =
          typeof overrides.zoom === "number"
            ? overrides.zoom / DEFAULT_CAMERA.zoom
            : 1;
        camera.zoom = clamp(
          autoZoom * multiplier * headerCompensation * mobileZoomOut,
          CAMERA_ZOOM_MIN,
          CAMERA_ZOOM_MAX
        );
      } else {
        camera.zoom = getCameraBase().zoom;
      }
      camera.rotX = getCameraBase().rotX;
      camera.rotY = getCameraBase().rotY;
      const mobileTilt = window.matchMedia("(max-width: 480px)").matches
        ? -10
        : window.matchMedia("(max-width: 960px)").matches
          ? -6
          : 0;
      camera.pan = 0;
      camera.tilt = mobileTilt;
      scene.showFloor =
        typeof sceneOverrides.showFloor === "boolean"
          ? sceneOverrides.showFloor
          : true;

      updateZoomUI();
      floorToggle.checked = scene.showFloor;
    };

    const loadModel = async (modelOrId) => {
      const model =
        typeof modelOrId === "string"
          ? models.find((m) => m.id === modelOrId)
          : modelOrId;
      if (!model) return;

      if (loadAbortController) {
        loadAbortController.abort();
      }
      const abortController =
        typeof AbortController !== "undefined" ? new AbortController() : null;
      loadAbortController = abortController;

      const token = ++requestToken;
      setError(null);
      setLoading(true);

      try {
        const revertSelection = () => {
          if (loadedModelId) {
            activeModelId = loadedModelId;
            renderTree();
            if (getRouteModelId()) {
              setRouteModelId(loadedModelId);
            }
          }
        };

        let voxels = [];
        if (model.type === "vox") {
          const res = await fetch(
            `/gallery/${model.path}`,
            abortController ? { signal: abortController.signal } : undefined
          );
          if (!res.ok) throw new Error("VOX fetch failed");
          const buffer = await res.arrayBuffer();
          if (abortController?.signal?.aborted) return;
          if (token !== requestToken) return;

          if (isProbablyIOS()) {
            const meta = readMagicaVoxelMeta(buffer);
            const voxelCount = meta?.voxelCount;
            if (typeof voxelCount === "number" && voxelCount > IOS_VOXEL_LIMIT) {
              setLoading(false);
              setError(`Model too large for iPhone (${safeNumberString(voxelCount)} voxels).`);
              revertSelection();
              return;
            }
          }
          const lib = await ensureVoxcss();
          if (!lib?.parseMagicaVoxel) throw new Error("Parser unavailable");
          const parsed = await lib.parseMagicaVoxel(buffer);
          voxels = Array.isArray(parsed?.voxels) ? parsed.voxels : [];
        } else {
          const res = await fetch(
            `/gallery/${model.path}`,
            abortController ? { signal: abortController.signal } : undefined
          );
          if (!res.ok) throw new Error("JSON fetch failed");
          const json = await res.json();
          voxels = Array.isArray(json) ? json : [];
        }

        if (abortController?.signal?.aborted) return;
        if (token !== requestToken) return;
        currentGrid = voxels;
        loadedModelId = model.id;
        setLoading(false);
        applyModelDefaults();
        await updateCamera();
        await updateScene();
      } catch (err) {
        if (abortController?.signal?.aborted || err?.name === "AbortError") return;
        if (token !== requestToken) return;
        setLoading(false);
        setError(
          typeof err?.message === "string" && err.message
            ? err.message
            : "Could not load model"
        );
        if (loadedModelId) {
          activeModelId = loadedModelId;
          renderTree();
          if (getRouteModelId()) {
            setRouteModelId(loadedModelId);
          }
        }
      } finally {
        if (loadAbortController === abortController) {
          loadAbortController = null;
        }
      }
    };

    const setActiveModel = (modelId, options = {}) => {
      const updateRoute = options.updateRoute === true;
      if (!modelId) return;
      const model = models.find((m) => m.id === modelId);
      if (!model) return;

      activeModelId = modelId;
      renderTree();
      if (updateRoute) setRouteModelId(modelId);
      if (modelId !== loadedModelId) {
        loadModel(model);
      }
    };

    const selectModel = (modelId) => {
      setActiveModel(modelId, { updateRoute: true });
    };

    const randomizeModel = () => {
      const filtered = getFilteredModels();
      const pool = filtered.length ? filtered : models;
      if (!pool.length) return;

      let next = pool[Math.floor(Math.random() * pool.length)] || pool[0];
      if (pool.length > 1 && activeModelId) {
        let guard = 0;
        while (next?.id === activeModelId && guard < 8) {
          next = pool[Math.floor(Math.random() * pool.length)] || pool[0];
          guard += 1;
        }
      }

      if (!next?.id) return;
      setActiveModel(next.id, { updateRoute: true });
    };

    // ── Event listeners ──────────────────────────────────────────────────────

    document.getElementById("btn-random-sidebar").addEventListener("click", randomizeModel);
    document.getElementById("btn-random-mobile").addEventListener("click", randomizeModel);

    const searchInput = document.getElementById("model-search");
    searchInput.addEventListener("input", () => {
      modelQuery = searchInput.value.trim();
      renderTree();
    });

    zoomSlider.addEventListener("input", () => {
      camera.zoom = Number(zoomSlider.value);
      zoomValueEl.textContent = camera.zoom.toFixed(2);
      updateCamera();
    });

    animateToggle.addEventListener("change", () => {
      camera.autoRotate = animateToggle.checked;
      updateCamera();
    });

    floorToggle.addEventListener("change", () => {
      scene.showFloor = floorToggle.checked;
      updateScene();
    });

    mergeSelect.addEventListener("change", () => {
      const v = mergeSelect.value;
      scene.mergeVoxels = v === "false" ? false : v;
      updateScene();
    });

    // Delegate model selection and category toggle from tree
    treeEl.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-model-id]");
      if (btn) {
        selectModel(decodeURIComponent(btn.dataset.modelId));
        return;
      }
      const catToggle = e.target.closest("button[data-toggle-cat]");
      if (catToggle) {
        const catId = catToggle.dataset.toggleCat;
        const next = !isCategoryOpen(catId);
        openCategories[catId] = next;
        renderTree();
      }
    });

    // ── Init ─────────────────────────────────────────────────────────────────

    const init = async () => {
      const routeModelId = getRouteModelId();
      if (routeModelId) {
        const resolvedId = resolveModelId(routeModelId);
        if (resolvedId) {
          activeModelId = resolvedId;
        } else {
          setRouteModelId(null);
        }
      } else if (models.length && !isProbablyIOS()) {
        const pool = models.filter((m) => getModelCategoryKey(m) === "scenes");
        const pickFrom = pool.length ? pool : models;
        const randomIndex = Math.floor(Math.random() * pickFrom.length);
        const randomModel = pickFrom[randomIndex] || pickFrom[0];
        if (randomModel?.id) {
          activeModelId = randomModel.id;
        }
      }

      renderTree();
      updateZoomUI();

      const activeModel = getActiveModel();
      if (activeModelId && activeModel) {
        await loadModel(activeModel);
      }
      await initRenderer();
    };

    init();

    // Handle popstate for back/forward navigation
    window.addEventListener("popstate", () => {
      const routeValue = getRouteModelId();
      if (!routeValue) return;
      const resolvedId = resolveModelId(routeValue);
      if (!resolvedId) {
        setRouteModelId(null);
        return;
      }
      if (resolvedId === activeModelId) return;
      setActiveModel(resolvedId, { updateRoute: false });
    });
  </script>

